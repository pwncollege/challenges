#!/bin/bash
# Pre-create the per-context sentinel files. The challenge binary opens these
# during its SUID-elevated setup phase to get FDs that survive the privilege
# drop; the files themselves stay root-owned and unreachable to the user.
for f in /challenge/.shell-sentinel /challenge/.gdb-sentinel; do
	: > "$f"
	chown root:root "$f"
	chmod 600 "$f"
done

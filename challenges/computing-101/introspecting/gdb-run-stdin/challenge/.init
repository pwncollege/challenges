#!/bin/bash
set -e

SECRET=$(python3 - <<'PY'
import secrets
print(secrets.token_urlsafe(18))
PY
)
NUM=$((RANDOM % 90000 + 10000))

printf '%s\n' "$SECRET" > /challenge/secret
printf '%s\n' "$NUM" > /challenge/.correct
chmod 644 /challenge/secret
chmod 600 /challenge/.correct

SRC=$(mktemp --suffix=.c)
cat > "$SRC" <<EOF
#define _GNU_SOURCE
#include <fcntl.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

#define SECRET "$SECRET"
#define NUM $NUM

static int is_traced(void) {
    int fd = open("/proc/self/status", O_RDONLY);
    if (fd < 0) return 0;
    char buf[4096];
    ssize_t n = read(fd, buf, sizeof buf - 1);
    close(fd);
    if (n <= 0) return 0;
    buf[n] = 0;
    char *p = strstr(buf, "TracerPid:");
    return p && atoi(p + sizeof("TracerPid:") - 1) != 0;
}

static int parent_is_gdb(void) {
    char path[64];
    snprintf(path, sizeof path, "/proc/%d/comm", getppid());
    int fd = open(path, O_RDONLY);
    if (fd < 0) return 0;
    char name[32];
    ssize_t n = read(fd, name, sizeof name - 1);
    close(fd);
    if (n <= 0) return 0;
    name[n] = 0;
    name[strcspn(name, "\n")] = 0;
    return strcmp(name, "gdb") == 0;
}

int main(void) {
    if (!is_traced() || !parent_is_gdb()) {
        puts("Run me under gdb for this challenge.");
        return 1;
    }

    char input[256];
    ssize_t n = read(0, input, sizeof input - 1);
    if (n < 0) {
        perror("read");
        return 1;
    }
    input[n] = 0;
    input[strcspn(input, "\n")] = 0;

    if (strcmp(input, SECRET) != 0) {
        puts("That was not the expected stdin.");
        return 1;
    }

    printf("secret number: %d\n", NUM);
    return 0;
}
EOF

gcc -O2 -o /challenge/debug-me "$SRC"
rm "$SRC"

#!/bin/bash

NUM=$((RANDOM % 65536))
echo $NUM > /challenge/.correct
chmod 600 /challenge/.correct

# Only reveals the secret when two args are passed
ASM=$(mktemp).o
as -o $ASM <<EOF
.intel_syntax noprefix

.global main
main:
    pop rdi
    cmp rdi, 3
    jne no_break

    mov rdi, $NUM
    int3

    mov rdi, 0
    mov rax, 60
    syscall

no_break:
    mov rdi, 0
    mov rax, 60
    syscall
EOF

ld -o /challenge/debug-me $ASM 2>/tmp/.init.log
rm $ASM

#!/bin/bash
# Builds /challenge/reverse-me at container start. The binary reads your argv[1]
# in fixed-size chunks (widths baked in per level), compares each chunk against
# an embedded little-endian immediate, and prints the flag once they all match.
# The password is randomized each run; the immediates are its chunks as the CPU
# reads them, so the learner recovers it by endian-correcting the disassembly.
set -e
WIDTHS="{{ widths }}"
SHUFFLE="{{ 1 if (shuffle is defined and shuffle) else 0 }}"
CHARSET="0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"

LEN=0
for W in $WIDTHS; do LEN=$((LEN + W)); done
PASSWORD=""
for ((i = 0; i < LEN; i++)); do PASSWORD="${PASSWORD}${CHARSET:$((RANDOM % 62)):1}"; done

emit_chunk() {  # $1 = width (bytes), $2 = offset; prints the load+compare for one chunk
    local W=$1 OFF=$2 IMM=0 j V
    for ((j = W - 1; j >= 0; j--)); do
        V=$(printf '%d' "'${PASSWORD:$((OFF + j)):1}")
        IMM=$(((IMM << 8) | V))   # little-endian: first char is the low byte
    done
    case $W in
        8) printf '  movabs rbx, %s\n  mov rax, [rdi+%s]\n  cmp rax, rbx\n  jne fail\n' "$IMM" "$OFF" ;;
        4) printf '  mov eax, [rdi+%s]\n  cmp eax, %s\n  jne fail\n' "$OFF" "$IMM" ;;
        2) printf '  mov ax, [rdi+%s]\n  cmp ax, %s\n  jne fail\n' "$OFF" "$IMM" ;;
        1) printf '  mov al, [rdi+%s]\n  cmp al, %s\n  jne fail\n' "$OFF" "$IMM" ;;
    esac
}

# Lay the fields out in memory order as "width:offset" pairs.
FIELDS=()
OFF=0
for W in $WIDTHS; do FIELDS+=("$W:$OFF"); OFF=$((OFF + W)); done
# When scrambling, check the fields in a random order so the disassembly's
# instruction order no longer matches the password's byte order. Re-roll if
# shuf happens to reproduce the memory order, so the level always exercises
# offset-tracking (the challenge promises you can't read straight down).
NFIELDS=$(printf '%s\n' "${FIELDS[@]}" | wc -l)
if [ "$SHUFFLE" = 1 ] && [ "$NFIELDS" -gt 1 ]; then
    MEMORDER="${FIELDS[*]}"
    FIELDS=($(printf '%s\n' "${FIELDS[@]}" | shuf))
    while [ "${FIELDS[*]}" = "$MEMORDER" ]; do
        FIELDS=($(printf '%s\n' "${FIELDS[@]}" | shuf))
    done
fi

SRC=$(mktemp --suffix=.s)
{
    printf '.intel_syntax noprefix\n.global _start\n_start:\n  mov rdi, [rsp+16]\n'
    for F in "${FIELDS[@]}"; do emit_chunk "${F%%:*}" "${F##*:}"; done
    cat <<'ASM'
  mov BYTE PTR [rsp], '/'
  mov BYTE PTR [rsp+1], 'f'
  mov BYTE PTR [rsp+2], 'l'
  mov BYTE PTR [rsp+3], 'a'
  mov BYTE PTR [rsp+4], 'g'
  mov BYTE PTR [rsp+5], 0
  mov rdi, rsp
  mov rsi, 0
  mov rax, 2
  syscall
  mov rdi, rax
  mov rsi, rsp
  mov rdx, 256
  mov rax, 0
  syscall
  mov rdx, rax
  mov rdi, 1
  mov rax, 1
  syscall
  mov rax, 60
  syscall
fail:
  mov rax, 60
  syscall
ASM
} > "$SRC"

OBJ=$(mktemp --suffix=.o)
as -o "$OBJ" "$SRC" 2>/tmp/.init.log
ld -o /challenge/reverse-me "$OBJ" 2>>/tmp/.init.log
chmod 4755 /challenge/reverse-me
rm -f "$SRC" "$OBJ"

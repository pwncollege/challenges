executable = True
give_flag = True

MODE = "{{ mode }}"


def word():
    alphabet = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_"
    return "".join(random.choice(alphabet) for _ in range(random.randint(1, 10)))


def feature_set():
    features = {"literal"}
    if MODE in ("printf-escapes", "printf-number", "printf-numbers", "printf-string", "printf-hex"):
        features.add("newline_escape")
    if MODE in ("printf-escapes", "printf-number", "printf-numbers", "printf-string", "printf-hex"):
        features.add("syntax_escapes")
    if MODE in ("printf-number", "printf-numbers", "printf-string", "printf-hex"):
        features.add("d")
    if MODE in ("printf-string", "printf-hex"):
        features.add("s")
    if MODE == "printf-hex":
        features.add("hex")
    return features


def cases():
    base = [
        ("", []),
        ("hello", []),
        ("score: ", []),
        (f"token-{word()}-done", []),
    ]
    if MODE == "printf-literal":
        return base

    actual_newlines = [
        ("hello\nworld", []),
        ("\n", []),
        ("a\nb\nc", []),
    ]
    if MODE == "printf-newline":
        return base + actual_newlines

    newline_escapes = [
        ("hello\\nworld", []),
        ("\\n", []),
        ("a\\nb\\nc", []),
    ]

    syntax_escapes = [
        ("path\\\\file", []),
        ("progress: 100%%", []),
        ("\\\\%%\\n", []),
        (f"{word()}\\\\{word()}%%", []),
    ]
    if MODE == "printf-escapes":
        return base + actual_newlines + newline_escapes + syntax_escapes

    single_numbers = [
        ("value=%d", ["42"]),
        ("%d", ["0"]),
        ("neg=%d", ["-12345"]),
        ("line\\nvalue=%d", ["42"]),
        ("random=%d", [str(random.randint(-(10**6), 10**6))]),
    ]
    if MODE == "printf-number":
        return base + actual_newlines + newline_escapes + syntax_escapes + single_numbers

    many_numbers = [
        ("opened %d files and skipped %d", ["7", "3"]),
        ("%d files, %d bytes, %d errors", ["4", "1024", "0"]),
        ("range %d..%d", ["-5", "5"]),
        ("release %d.%d.%d", ["1", "2", "3"]),
    ]
    if MODE == "printf-numbers":
        return base + actual_newlines + newline_escapes + syntax_escapes + single_numbers + many_numbers

    strings = [
        ("hello, %s", ["hacker"]),
        ("%s", ["LITERAL\\WITH\\SLASHES"]),
        ("%s:%d", ["count", "5"]),
        ("%s\\n%d", ["row", "7"]),
        ("%d:%s:%d", ["7", "left", "-2"]),
        ("empty=%s.", [""]),
        (f"{word()}=%s", [word()]),
    ]
    if MODE == "printf-string":
        return base + actual_newlines + newline_escapes + syntax_escapes + single_numbers + many_numbers + strings

    hexes = [
        ("\\x41\\x42\\x43", []),
        ("A\\x00B", []),
        ("%s\\x20%d", ["answer", "42"]),
        ("\\x7e\\n", []),
        ("byte=\\x2a", []),
    ]
    return base + actual_newlines + newline_escapes + syntax_escapes + single_numbers + many_numbers + strings + hexes


def parse_hex_digit(ch):
    if "0" <= ch <= "9":
        return ord(ch) - ord("0")
    if "a" <= ch <= "f":
        return ord(ch) - ord("a") + 10
    if "A" <= ch <= "F":
        return ord(ch) - ord("A") + 10
    raise AssertionError(f"test bug: invalid hex digit {ch!r}")


def render(fmt, args, features):
    out = bytearray()
    argi = 0
    i = 0
    while i < len(fmt):
        ch = fmt[i]

        if ch == "%" and ("syntax_escapes" in features or "d" in features or "s" in features):
            assert i + 1 < len(fmt), "test bug: dangling %"
            spec = fmt[i + 1]
            if spec == "%" and "syntax_escapes" in features:
                out.append(ord("%"))
                i += 2
                continue
            assert spec in features, f"test bug: unsupported %{spec}"
            assert argi < len(args), "test bug: missing format argument"
            if spec == "d":
                out.extend(str(int(args[argi])).encode())
            else:
                out.extend(args[argi].encode("latin-1"))
            argi += 1
            i += 2
            continue

        if ch == "\\" and ("newline_escape" in features or "syntax_escapes" in features or "hex" in features):
            assert i + 1 < len(fmt), "test bug: dangling backslash"
            esc = fmt[i + 1]
            if esc == "\\" and "syntax_escapes" in features:
                out.append(ord("\\"))
                i += 2
                continue
            if esc == "n" and "newline_escape" in features:
                out.append(0x0A)
                i += 2
                continue
            if esc == "x" and "hex" in features:
                assert i + 3 < len(fmt), "test bug: short hex escape"
                out.append((parse_hex_digit(fmt[i + 2]) << 4) | parse_hex_digit(fmt[i + 3]))
                i += 4
                continue

        out.extend(ch.encode("latin-1"))
        i += 1

    assert argi == len(args), "test bug: unused format argument"
    return bytes(out)


def quote_text(text):
    pieces = []
    for ch in text:
        value = ord(ch)
        if ch == "\\":
            pieces.append("\\\\")
        elif ch == "'":
            pieces.append("\\'")
        elif ch == "\n":
            pieces.append("\\n")
        elif 32 <= value <= 126:
            pieces.append(ch)
        else:
            pieces.append(f"\\x{value:02x}")
    return "'" + "".join(pieces) + "'"


def describe_text(text, name_newlines=False):
    if name_newlines and "\n" in text:
        count = text.count("\n")
        if text == "\n":
            return "one newline byte"
        if count == 1:
            return "text containing one newline byte"
        return f"text containing {count} newline bytes"
    return quote_text(text)


def describe_bytes(data, name_newlines=False):
    if not data:
        return "nothing"
    return describe_text(data.decode("latin-1"), name_newlines)


def describe_args(args):
    if not args:
        return "no extra values"
    if len(args) == 1:
        return f"extra value {quote_text(args[0])}"
    return "extra values " + ", ".join(quote_text(arg) for arg in args)


def describe_case(fmt, args, name_newlines=False):
    return f"format {describe_text(fmt, name_newlines)} with {describe_args(args)}"


def diagnose(fmt, args, expected, got):
    if "%s" in fmt and any("\\" in arg for arg in args) and got != expected:
        return (
            " A %s argument should be copied literally. Do not run argv strings through "
            "your format-string scanner; escapes only apply inside the format string."
        )
    if b"%d" in got or b"%s" in got:
        return " A percent marker was copied literally instead of being handled."
    if "%%" in fmt and b"%%" in got:
        return " The two percent bytes should become one percent byte."
    if "\\\\" in fmt and b"\\\\" in got:
        return " The two backslash bytes should become one backslash byte."
    if "\\n" in fmt and b"\\n" in got:
        return " The two bytes backslash+n should become one newline byte."
    if "\\x" in fmt and b"\\x" in got:
        return " A hex escape should become one byte, not four printed characters."
    return ""



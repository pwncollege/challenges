def check_runtime(binary_path):
    checker.print_prompt()
    if MODE in ("printf-number", "printf-numbers", "printf-string", "printf-hex"):
        checker.slow_print(f"{binary_path} FORMAT_TEXT EXTRA_VALUE ...")
    else:
        checker.slow_print(f"{binary_path} FORMAT_TEXT")
    print("")

    features = feature_set()
    name_newlines = MODE == "printf-newline"
    for i, (fmt, args) in enumerate(cases()):
        case = describe_case(fmt, args, name_newlines)
        expected = render(fmt, args, features)
        try:
            p = subprocess.run(
                [binary_path, fmt, *args],
                stdout=subprocess.PIPE,
                stderr=(subprocess.DEVNULL if i != 0 else None),
                timeout=5,
            )
        except subprocess.TimeoutExpired:
            raise AssertionError(
                f"Your program did not finish on {case}. "
                "Make sure the format scan advances on every path."
            )
        if p.returncode < 0:
            signum = -p.returncode
            signame = signal.Signals(signum).name if signum in signal.Signals._value2member_map_ else f"signal {signum}"
            raise AssertionError(f"Your program crashed ({signame}) on {case}.")
        if p.returncode != 0:
            raise AssertionError(
                f"On {case}, your program should print {describe_bytes(expected, name_newlines)} "
                f"and exit cleanly, but it exited with status {p.returncode}."
                f"{diagnose(fmt, args, expected, p.stdout)}"
            )
        assert p.stdout == expected, (
            f"On {case}, your program should print {describe_bytes(expected, name_newlines)}, "
            f"but it printed {describe_bytes(p.stdout, name_newlines)}.{diagnose(fmt, args, expected, p.stdout)}"
        )
        print(f"  ok: {case} printed {describe_bytes(p.stdout, name_newlines)}")
    return True

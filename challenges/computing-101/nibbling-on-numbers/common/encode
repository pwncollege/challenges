#!/usr/bin/exec-suid -- /usr/bin/python3 -I

import random
import sys

WIDTH = {{ width }}
MOD = 1 << WIDTH         # 2**WIDTH
HIGH = 1 << (WIDTH - 1)  # the sign bit
MAX_ATTEMPTS = 3

# Read the flag now, while we have the privileges to (this program is SUID).
with open("/flag") as f:
    flag = f.read()

# A guaranteed mix of negative and non-negative numbers.
nums = [random.randint(-HIGH, -1) for _ in range({{ n_neg }})] + \
       [random.randint(0, HIGH - 1) for _ in range({{ n_pos }})]
random.shuffle(nums)

print(f"Now the other direction: I give you a number, and you encode it in {WIDTH}-bit")
print("two's complement, written in binary.")
print("A zero-or-positive number is just its plain binary. For a negative number, its")
print(f"{WIDTH}-bit pattern is the same bits as the unsigned value (the number + {MOD}), so its")
print("top bit ends up set.\n")
print(f"I'll give you {len(nums)} numbers. Write each one's {WIDTH}-bit binary.\n")

for i, n in enumerate(nums, 1):
    expected = n % MOD  # the two's-complement bit pattern, as an integer
    print(f"Number {i} of {len(nums)}:  {n}")
    for attempt in range(MAX_ATTEMPTS):
        try:
            got = int(input(f"  as {WIDTH}-bit two's-complement binary > ").strip().replace(" ", ""), 2)
        except (EOFError, ValueError):
            print("  That doesn't look like binary.")
        else:
            if got == expected:
                print("  Correct!\n")
                break

            hint = ""
            if n < 0 and got == -n:
                hint = f" (That's just the magnitude. For {n}, encode {n} + {MOD} = {expected}.)"
            print(f"  Not quite --- {n} in {WIDTH}-bit two's complement is {format(expected, f'0{WIDTH}b')}.{hint}")

        if attempt < MAX_ATTEMPTS - 1:
            print("  Try this one again.")
    else:
        print("  Run me again when you're ready.")
        sys.exit(1)

print("All correct --- you can write two's complement! Here is your flag:")
print(flag)

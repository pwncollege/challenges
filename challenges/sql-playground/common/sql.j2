#!/usr/bin/exec-suid -- /usr/local/bin/python3 -I

{% import "random_names.j2" as random_names with context %}
{% set table_name = table_name | default(random_names.table_name) %}
{% set column_name = column_name | default(random_names.column_name) %}
{% set db_state = db_state | default("trivial") %}
{% set doc_hint = doc_hint | default(None) %}
{% set num_queries = num_queries | default(1) %}
{% set max_rows = max_rows | default(None) %}
{% set max_columns = max_columns | default(None) %}
{% set max_characters = max_characters | default(None) %}
{% set flag_tag = flag_tag | default(False) %}
{% set tag_value_noflag = tag_value_noflag | default(1) %}
{% set tag_value_flag = tag_value_flag | default(1337) %}
{% set random_flag_tag = random_flag_tag | default(False) %}
{% set decoy_flags = decoy_flags | default(False) %}

import sys
import string
import random
import sqlite3
import tempfile

# Don't panic about the TemporaryDB class. It simply implements a temporary database
# in which this application can store data. You don't need to understand its internals,
# just that it processes SQL queries using db.execute().
class TemporaryDB:
    def __init__(self):
        self.db_file = tempfile.NamedTemporaryFile("x", suffix=".db")

    def execute(self, sql, parameters=()):
        connection = sqlite3.connect(self.db_file.name)
        connection.row_factory = sqlite3.Row
        cursor = connection.cursor()
        result = cursor.execute(sql, parameters)
        connection.commit()
        return result

db = TemporaryDB()

{% if db_state == "trivial" -%}
# https://www.sqlite.org/lang_createtable.html
db.execute("""CREATE TABLE {{table_name}} AS SELECT ? as {{column_name}}""", [open("/flag").read().strip()])
{% elif db_state == "flooded" -%}
def random_word(length):
    return "".join(random.sample(string.ascii_letters*10, length))
flag = open("/flag").read().strip()

# https://www.sqlite.org/lang_createtable.html
db.execute("""CREATE TABLE {{table_name}} AS SELECT {% if flag_tag %}{{tag_value_noflag}} as flag_tag, {% endif %}? as {{column_name}}""", [random_word(len(flag))])
# https://www.sqlite.org/lang_insert.html
for i in range(random.randrange(5, 42)):
    db.execute("""INSERT INTO {{table_name}} VALUES({% if flag_tag %}{{tag_value_noflag}}, {%endif%}?)""", [random_word(len(flag))])
db.execute("""INSERT INTO {{table_name}} VALUES({% if flag_tag %}?, {% endif %}?)""", [{% if flag_tag %}{% if random_flag_tag %}random.randrange(1337, 313371337){% else %}{{tag_value_flag}}{% endif %}, {% endif %}flag])

{% if decoy_flags %}
for i in range(random.randrange(5, 21)):
    db.execute("""INSERT INTO {{table_name}} VALUES({% if flag_tag %}{{tag_value_flag}}, {% endif %}?)""", [random_word(len(flag))])
for i in range(random.randrange(5, 21)):
    db.execute("""INSERT INTO {{table_name}} VALUES({% if flag_tag %}{{tag_value_noflag}}, {% endif %}?)""", ["pwn.college{"+random_word(len(flag)-len("pwn.college{}"))+"}"])
{% endif %}

for i in range(random.randrange(5, 42)):
    db.execute("""INSERT INTO {{table_name}} VALUES({% if flag_tag %}{{tag_value_noflag}}, {% endif %}?)""", [random_word(len(flag))])
{% elif db_state == "randomized" -%}
random_table_name = "".join(random.sample(string.ascii_letters, 8))
db.execute(f"""CREATE TABLE {random_table_name} AS SELECT ? as {{column_name}}""", [open("/flag").read().strip()])
{% endif %}

{% if doc_hint %}
# HINT: {{doc_hint}}
{% endif -%}
for _ in range({{num_queries}}):
    query = input("sql> ")

    try:
        results = db.execute(query).fetchall()
    except sqlite3.Error as e:
        print("SQL ERROR:", e)
        sys.exit(1)

    if len(results) == 0:
        print("No results returned!")
        sys.exit(0)

    {% if max_rows -%}
    if len(results) > {{max_rows}}:
        print("You're not allowed to read this many rows!")
        sys.exit(1)
    {% endif -%}

    {% if max_columns -%}
    if len(results[0].keys()) > {{max_columns}}:
        print("You're not allowed to read this many columns!")
        sys.exit(1)
    {% endif -%}

    {% if max_characters -%}
    for row in results:
        for k in row.keys():
            if type(row[k]) in (str, bytes) and len(row[k]) > {{max_characters}}:
                print("You're not allowed to read this many characters!")
                sys.exit(1)
    {% endif -%}

    print(f"Got {len(results)} rows.")
    for row in results:
        print(f"- { { k:row[k] for k in row.keys() } }")

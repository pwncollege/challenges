#!/usr/bin/env python3

import subprocess
import requests
import atexit
import time

proc = subprocess.Popen(['/challenge/server'])
for _ in range(75):
    try:
        requests.get("http://challenge.localhost/", timeout=1)
        break
    except requests.RequestException:
        time.sleep(0.2)
else:
    raise AssertionError("server did not become ready in time")


# Test normal query
response = requests.get(
    "http://challenge.localhost/",
    params={"query": "admin"}
)
assert response.status_code == 200
assert "admin" in response.text
assert "REDACTED" in response.text  # Table name should be redacted

# Test wildcard query
response = requests.get(
    "http://challenge.localhost/",
    params={"query": "%"}
)
assert response.status_code == 200
assert "admin" in response.text or "guest" in response.text

print("Normal functionality tests passed")
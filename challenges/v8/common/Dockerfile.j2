{%- set pwn_v8_revision_value = pwn_v8_revision | default('', true) | trim -%}
{%- set pwn_challenge_profile_value = pwn_challenge_cache_key | default('', true) | trim -%}
{%- set pwn_challenge_context_value = pwn_challenge_profile_value ~ "-" ~ pwn_v8_revision_value ~ "-ctx3" -%}
FROM ubuntu:24.04 AS v8-builder

RUN apt-get update && apt-get install -y \
    git curl python3 lsb-release sudo \
    build-essential pkg-config libglib2.0-dev xz-utils patch

RUN git clone https://chromium.googlesource.com/chromium/tools/depot_tools.git /opt/depot_tools
ENV PATH="/opt/depot_tools:${PATH}"

WORKDIR /build
RUN echo "solutions = [{'name': 'v8', 'url': 'https://chromium.googlesource.com/v8/v8.git', 'deps_file': 'DEPS', 'managed': False}]" > .gclient
RUN git clone https://chromium.googlesource.com/v8/v8.git

WORKDIR /build/v8

ARG PWN_V8_REVISION="{{ pwn_v8_revision_value }}"
RUN set -eux; \
    REVISION="$PWN_V8_REVISION"; \
    test -n "$REVISION"; \
    echo "$REVISION" > /tmp/pwn-v8-revision-cache-key
RUN set -eux; \
    REVISION="$(cat /tmp/pwn-v8-revision-cache-key)"; \
    echo "$REVISION" > /tmp/REVISION; \
    git fetch --depth=1 origin "$REVISION"; \
    git checkout --detach "$REVISION"
RUN ln -sf /usr/bin/python3 /usr/bin/python
RUN gclient sync
# Fix Python 3.12 incompatibilities in old V8 bundled dependencies
RUN find third_party -name '*.py' -exec grep -l 'from collections import' {} + 2>/dev/null | \
    xargs -r sed -i 's/from collections import Mapping/from collections.abc import Mapping/g' || true
RUN find third_party -name '*.py' -exec grep -l 'import collections' {} + 2>/dev/null | \
    xargs -r sed -i 's/collections\.Mapping/collections.abc.Mapping/g' || true
# Some V8 revisions pin a toolchain whose bundled libstdc++ is older than Ubuntu 24.04's
# C++ runtime deps (e.g., ICU), causing link failures. Prefer the system libstdc++.
RUN ln -sf /usr/lib/x86_64-linux-gnu/libstdc++.so.6 third_party/llvm-build/Release+Asserts/lib/libstdc++.so.6

COPY args.gn /tmp/args.gn
RUN mkdir -p out/release && cp /tmp/args.gn out/release/args.gn
RUN gn gen out/release
RUN apt-get install -y ninja-build

# Build an unpatched baseline once per (REVISION, args.gn). This layer can be
# reused across many challenges, and makes the subsequent patch build mostly
# incremental instead of a full rebuild.
RUN autoninja -C out/release d8

COPY patch /tmp/patch
RUN if [ -s /tmp/patch ]; then git apply /tmp/patch || patch -p1 --fuzz=3 < /tmp/patch; fi
{% include "d8-shell-hardening.j2" %}

# Re-generate build files in case the patch touched BUILD.gn/torque/etc, then
# rebuild incrementally.
RUN gn gen out/release
RUN autoninja -C out/release d8

FROM ubuntu:24.04 AS wasm-tools-stage

ADD https://github.com/bytecodealliance/wasm-tools/releases/download/v1.251.0/wasm-tools-1.251.0-x86_64-linux.tar.gz /tmp/wasm-tools.tar.gz
RUN tar -xzf /tmp/wasm-tools.tar.gz -C /tmp && \
    cp /tmp/wasm-tools-1.251.0-x86_64-linux/wasm-tools /wasm-tools && \
    chmod 755 /wasm-tools

FROM ubuntu:24.04

RUN apt-get update && apt-get install -y adduser gcc && rm -rf /var/lib/apt/lists/*
COPY --from=wasm-tools-stage /wasm-tools /usr/bin/wasm-tools
RUN printf '%s\n' \
    '#!/bin/sh' \
    'set -eu' \
    '' \
    'if [ "$#" -ne 2 ]; then' \
    '    echo "usage: wasm-wat2js JS_IDENTIFIER INPUT.wat" >&2' \
    '    exit 1' \
    'fi' \
    '' \
    'name="$1"' \
    'wat="$2"' \
    'case "$name" in' \
    '    ""|*[!A-Za-z0-9_$]*|[0-9]*)' \
    '        echo "error: JS identifier must match [A-Za-z_$][A-Za-z0-9_$]*" >&2' \
    '        exit 1' \
    '        ;;' \
    'esac' \
    'if [ ! -r "$wat" ]; then' \
    '    echo "error: WAT file is not readable: $wat" >&2' \
    '    exit 1' \
    'fi' \
    '' \
    'tmp="$(mktemp)"' \
    'cleanup() {' \
    '    rm -f "$tmp"' \
    '}' \
    'trap cleanup EXIT' \
    '' \
    '/usr/bin/wasm-tools parse "$wat" -o "$tmp"' \
    'printf "const %s = new Uint8Array([\\n" "$name"' \
    'for byte in $(od -An -v -tu1 "$tmp"); do' \
    '    printf "  %s,\\n" "$byte"' \
    'done' \
    'printf "]);\\n"' \
    > /usr/bin/wasm-wat2js && chmod 755 /usr/bin/wasm-wat2js

# Legacy builder (DOCKER_BUILDKIT=0) doesn't support ADD's --chmod/--chown flags.
# Use a plain ADD and fix ownership/mode in a separate RUN (works for both).
ADD http://github.com/pwncollege/exec-suid/releases/latest/download/exec-suid /usr/bin/exec-suid
RUN chown 0:0 /usr/bin/exec-suid && chmod 6755 /usr/bin/exec-suid

ARG PWN_CHALLENGE_PROFILE="{{ pwn_challenge_profile_value }}"
RUN test -z "$PWN_CHALLENGE_PROFILE" || echo "$PWN_CHALLENGE_PROFILE" > /tmp/pwn-challenge-profile
COPY . /tmp/pwn-challenge-context-{{ pwn_challenge_context_value }}
RUN rm -rf /challenge && mv /tmp/pwn-challenge-context-{{ pwn_challenge_context_value }} /challenge
RUN if [ -f /challenge/REVISION ]; then \
    actual="$(cat /challenge/REVISION)"; \
    expected="{{ pwn_v8_revision_value }}"; \
    test "$actual" = "$expected" || { echo "REVISION mismatch: $actual != $expected" >&2; exit 1; }; \
    fi

COPY --from=v8-builder /build/v8/out/release/d8 /challenge/d8
COPY --from=v8-builder /build/v8/out/release/snapshot_blob.bin /challenge/snapshot_blob.bin
COPY --from=v8-builder /build/v8/out/release/icudtl.dat /challenge/icudtl.dat

RUN gcc -static -o /challenge/catflag /challenge/catflag.c && rm -f /challenge/catflag.c
RUN rm -f /challenge/Dockerfile /challenge/.setup

function createWasmFXImportedTagNativePrimitive() {
    function read32Caged(offset) {
        return new DataView(new realSandbox.MemoryView(Number(offset), 4)).getUint32(0, true);
    }

    function write32Caged(offset, value) {
        new DataView(new realSandbox.MemoryView(Number(offset), 4)).setUint32(0, Number(value) >>> 0, true);
    }

    function isTaggedReference(value) {
        return (value & 1) === 1;
    }

    const tagFactory = new WebAssembly.Instance(new WebAssembly.Module(tagFactoryBytes), {}).exports;
    const tagA = tagFactory.tagA;
    const tagB = tagFactory.tagB;
    const tagAOffset = realSandbox.getAddressOf(tagA);
    const tagBOffset = realSandbox.getAddressOf(tagB);
    const maxOffset = Math.min(realSandbox.getSizeOf(tagA), realSandbox.getSizeOf(tagB), 0x80);

    let identityField;
    for (let offset = 8; offset < maxOffset; offset += 4) {
        const tagAIdentity = read32Caged(tagAOffset + offset) >>> 0;
        const tagBIdentity = read32Caged(tagBOffset + offset) >>> 0;
        if (!isTaggedReference(tagAIdentity) || !isTaggedReference(tagBIdentity) || tagAIdentity === tagBIdentity) continue;

        const tagAIndex = read32Caged((tagAIdentity - 1) + 4) >>> 1;
        const tagBIndex = read32Caged((tagBIdentity - 1) + 4) >>> 1;
        if (tagAIndex === 0 && tagBIndex === 1) {
            identityField = { offset, tagAIdentity };
            break;
        }
    }
    if (identityField === undefined) {
        throw new Error("failed to locate the WebAssembly.Tag identity field");
    }

    write32Caged(tagBOffset + identityField.offset, identityField.tagAIdentity);
    const exports = new WebAssembly.Instance(
        new WebAssembly.Module(importedTagNativeProbeBytes),
        { m: { tagA, tagB } },
    ).exports;

    exports.init_box(0x41424344);
    const leakedPointer = BigInt(exports.leak_box_ptr());
    const boxField = leakedPointer + 7n;
    const before = exports.native_read32(boxField) >>> 0;
    exports.native_write32(boxField, 0x55667788);
    const after = exports.native_read32(boxField) >>> 0;
    if (before !== 0x41424344 || after !== 0x55667788) {
        throw new Error("WasmFX imported-tag native primitive self-test failed");
    }

    return Object.freeze({
        leakedPointer,
        read32(address) {
            return exports.native_read32(BigInt(address)) >>> 0;
        },
        write32(address, value) {
            exports.native_write32(BigInt(address), value >>> 0);
        },
    });
}

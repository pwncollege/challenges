{% include "../../../common/provided-process-memory.js.j2" %}

const primitive = createProvidedProcessMemory();

Object.defineProperty(globalThis, "Sandbox", {
    value: undefined,
    writable: false,
    configurable: false,
});

const PROCESS_IMAGE_BASE = 0x555555554000n;
const ELF_MAGIC_QWORD = 0x00010102464c457fn;
const PT_LOAD = 1;
const PT_DYNAMIC = 2;
const PF_X = 1;
const PF_W = 2;
const DT_NULL = 0n;
const DT_PLTRELSZ = 2n;
const DT_STRTAB = 5n;
const DT_SYMTAB = 6n;
const DT_RELAENT = 9n;
const DT_SYMENT = 11n;
const DT_JMPREL = 23n;

function fail(message) {
    throw new Error(message);
}

function read8(address) {
    address = BigInt(address);
    const aligned = address & ~7n;
    return Number((primitive.read64(aligned) >> ((address - aligned) * 8n)) & 0xffn);
}

function read16(address) {
    return read8(address) | (read8(BigInt(address) + 1n) << 8);
}

function read32(address) {
    return (
        read8(address) |
        (read8(BigInt(address) + 1n) << 8) |
        (read8(BigInt(address) + 2n) << 16) |
        (read8(BigInt(address) + 3n) << 24)
    ) >>> 0;
}

function read64(address) {
    return primitive.read64(BigInt(address));
}

function readCString(address, limit = 96) {
    let result = "";
    for (let i = 0; i < limit; i++) {
        const byte = read8(BigInt(address) + BigInt(i));
        if (byte === 0) break;
        result += String.fromCharCode(byte);
    }
    return result;
}

let learnerReadCalls = 0;

function learnerRead32(address) {
    learnerReadCalls++;
    return read32(address);
}

function learnerRead64(address) {
    learnerReadCalls++;
    return read64(address);
}

function learnerReadCString(address, limit = 96) {
    learnerReadCalls++;
    return readCString(address, limit);
}

function ptrFromDynamicValue(value) {
    value = BigInt(value);
    return value >= PROCESS_IMAGE_BASE ? value : PROCESS_IMAGE_BASE + value;
}

function parseProgramHeaders() {
    if (read64(PROCESS_IMAGE_BASE) !== ELF_MAGIC_QWORD) {
        fail("Harness error: unexpected process-image ELF base.");
    }

    const ePhOff = read64(PROCESS_IMAGE_BASE + 0x20n);
    const ePhEntSize = read16(PROCESS_IMAGE_BASE + 0x36n);
    const ePhNum = read16(PROCESS_IMAGE_BASE + 0x38n);
    const result = { dynamicAddress: 0n, dynamicSize: 0n };

    for (let i = 0; i < ePhNum; i++) {
        const ph = PROCESS_IMAGE_BASE + ePhOff + BigInt(i * ePhEntSize);
        const type = read32(ph);
        const vaddr = read64(ph + 0x10n);
        const filesz = read64(ph + 0x20n);
        if (type === PT_DYNAMIC) {
            result.dynamicAddress = PROCESS_IMAGE_BASE + vaddr;
            result.dynamicSize = filesz;
        }
    }

    if (result.dynamicAddress === 0n) {
        fail("Harness error: failed to locate d8 dynamic table.");
    }
    return Object.freeze(result);
}

function parseDynamicTables(programHeaders) {
    const result = {
        strtab: 0n,
        symtab: 0n,
        syment: 24n,
        jmprel: 0n,
        pltrelsz: 0n,
        relaent: 24n,
    };

    for (let entry = programHeaders.dynamicAddress; entry < programHeaders.dynamicAddress + programHeaders.dynamicSize; entry += 16n) {
        const tag = read64(entry);
        const value = read64(entry + 8n);
        if (tag === DT_NULL) break;
        if (tag === DT_STRTAB) result.strtab = ptrFromDynamicValue(value);
        else if (tag === DT_SYMTAB) result.symtab = ptrFromDynamicValue(value);
        else if (tag === DT_SYMENT) result.syment = value;
        else if (tag === DT_JMPREL) result.jmprel = ptrFromDynamicValue(value);
        else if (tag === DT_PLTRELSZ) result.pltrelsz = value;
        else if (tag === DT_RELAENT) result.relaent = value;
    }

    if (result.strtab === 0n || result.symtab === 0n || result.jmprel === 0n || result.pltrelsz === 0n) {
        fail("Harness error: failed to parse d8 dynamic entries.");
    }
    return Object.freeze(result);
}

function resolveImports(tables) {
    const result = {};
    for (let relocation = tables.jmprel; relocation < tables.jmprel + tables.pltrelsz; relocation += tables.relaent) {
        let got = read64(relocation);
        if (got < PROCESS_IMAGE_BASE) got += PROCESS_IMAGE_BASE;
        const info = read64(relocation + 8n);
        const symbolIndex = info >> 32n;
        const symbol = tables.symtab + symbolIndex * tables.syment;
        const nameOffset = read32(symbol);
        const name = readCString(tables.strtab + BigInt(nameOffset));
        if (name === "syscall") result.syscallGot = got;
        if (name === "exit") result.exitGot = got;
    }
    if (result.syscallGot === undefined || result.exitGot === undefined) {
        fail("Harness error: failed to resolve syscall/exit PLT relocations.");
    }
    result.syscallTarget = read64(result.syscallGot);
    result.exitTarget = read64(result.exitGot);
    return Object.freeze(result);
}

function normalizeBigInt(value, name) {
    if (typeof value === "bigint") return value;
    const asNumber = Number(value);
    if (!Number.isSafeInteger(asNumber)) {
        fail(`${name} must be returned as a BigInt.`);
    }
    return BigInt(asNumber);
}

function checkField(actual, expected, name) {
    const value = normalizeBigInt(actual, name);
    if (value !== expected) {
        fail(`${name} was 0x${value.toString(16)}; expected 0x${expected.toString(16)}.`);
    }
}

const tables = parseDynamicTables(parseProgramHeaders());
const expected = resolveImports(tables);
const api = Object.freeze({
    baseAddress: PROCESS_IMAGE_BASE,
    strtab: tables.strtab,
    symtab: tables.symtab,
    syment: tables.syment,
    jmprel: tables.jmprel,
    pltrelsz: tables.pltrelsz,
    relaent: tables.relaent,
    read32: learnerRead32,
    read64: learnerRead64,
    readCString: learnerReadCString,
});

__PWN_SOLVE_SOURCE__;

if (typeof solve !== "function") {
    fail("define solve(api)");
}

const result = solve(api);
if (result === null || typeof result !== "object") {
    fail("Return an object with syscallGot, exitGot, syscallTarget, and exitTarget.");
}

for (const field of ["syscallGot", "exitGot", "syscallTarget", "exitTarget"]) {
    checkField(result[field], expected[field], field);
}

if (learnerReadCalls === 0) {
    fail("Resolve the imports by reading the provided PLT relocation and symbol-table data.");
}

print("__PWN_SUCCESS_MARKER__");

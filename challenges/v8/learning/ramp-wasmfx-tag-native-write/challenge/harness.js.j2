{% extends "../../../common/sandbox-guard-harness.js.j2" %}

{% block setup %}
const expectedToken = 0x55667788;
const initialProofValue = 0x41424344;
const proofFieldDelta = 7n;
const tagFactoryBytes = new Uint8Array([
    0, 97, 115, 109, 1, 0, 0, 0, 1, 17, 3, 95, 1, 127, 1, 96,
    2, 100, 0, 126, 0, 96, 2, 126, 100, 0, 0, 13, 5, 2, 0,
    1, 0, 2, 7, 15, 2, 4, 116, 97, 103, 65, 4, 0, 4,
    116, 97, 103, 66, 4, 1,
]);
const importedTagNativeProbeBytes = new Uint8Array([
    0, 97, 115, 109, 1, 0, 0, 0, 1, 51, 11, 95, 1, 127,
    1, 96, 2, 100, 0, 126, 0, 96, 2, 126, 100, 0, 0, 96,
    0, 0, 93, 3, 96, 0, 0, 96, 0, 3, 126, 100, 0, 100,
    4, 96, 1, 127, 0, 96, 0, 1, 126, 96, 1, 126, 1, 127,
    96, 2, 126, 127, 0, 2, 21, 2, 1, 109, 4, 116, 97, 103,
    65, 4, 0, 1, 1, 109, 4, 116, 97, 103, 66, 4, 0, 2,
    3, 6, 5, 5, 7, 8, 9, 10, 6, 17, 3, 99, 0, 1, 208,
    0, 11, 126, 1, 66, 0, 11, 126, 1, 66, 0, 11, 7, 83,
    7, 4, 103, 66, 111, 120, 3, 0, 5, 103, 76, 101, 97, 107,
    3, 1, 5, 103, 65, 100, 100, 114, 3, 2, 8, 105, 110, 105,
    116, 95, 98, 111, 120, 0, 1, 12, 108, 101, 97, 107, 95, 98,
    111, 120, 95, 112, 116, 114, 0, 2, 13, 110, 97, 116, 105, 118,
    101, 95, 114, 101, 97, 100, 51, 50, 0, 3, 14, 110, 97, 116,
    105, 118, 101, 95, 119, 114, 105, 116, 101, 51, 50, 0, 4, 9,
    5, 1, 3, 0, 1, 0, 10, 132, 1, 5, 9, 0, 35, 0, 212,
    35, 2, 226, 0, 11, 9, 0, 32, 0, 251, 0, 0, 36, 0,
    11, 34, 0, 66, 136, 239, 153, 171, 197, 232, 140, 145, 17, 36,
    2, 2, 6, 210, 0, 224, 4, 227, 4, 1, 0, 1, 0, 0,
    11, 26, 26, 36, 1, 35, 1, 11, 36, 1, 1, 100, 0, 32,
    0, 66, 7, 125, 36, 2, 2, 6, 210, 0, 224, 4, 227, 4,
    1, 0, 1, 0, 0, 11, 26, 33, 1, 26, 32, 1, 251, 2,
    0, 0, 11, 38, 1, 1, 100, 0, 32, 0, 66, 7, 125, 36,
    2, 2, 6, 210, 0, 224, 4, 227, 4, 1, 0, 1, 0, 0,
    11, 26, 33, 2, 26, 32, 2, 32, 1, 251, 5, 0, 0, 11,
    0, 74, 4, 110, 97, 109, 101, 1, 67, 5, 0, 9, 115, 117,
    115, 112, 101, 110, 100, 101, 114, 1, 8, 105, 110, 105, 116, 95,
    98, 111, 120, 2, 12, 108, 101, 97, 107, 95, 98, 111, 120, 95,
    112, 116, 114, 3, 13, 110, 97, 116, 105, 118, 101, 95, 114, 101,
    97, 100, 51, 50, 4, 14, 110, 97, 116, 105, 118, 101, 95, 119,
    114, 105, 116, 101, 51, 50,
]);

const tagFactory = new WebAssembly.Instance(new WebAssembly.Module(tagFactoryBytes), {}).exports;
const tagA = tagFactory.tagA;
const tagB = tagFactory.tagB;
const tagAOffset = guardTools.realSandbox.getAddressOf(tagA);
const tagBOffset = guardTools.realSandbox.getAddressOf(tagB);
const tagASize = guardTools.realSandbox.getSizeOf(tagA);
const tagBSize = guardTools.realSandbox.getSizeOf(tagB);
let activeProbe;
let activeProbeWrapper;
let proofBoxPointer;
let initializedProofBox = false;
let leakedProofBox = false;
let leakHelperUsed = false;
let nativeWriteCalls = 0;
let derivedProofFieldAddress;

function read32(offset) {
    return guardTools.readUint32(offset);
}

function isTaggedReference(value) {
    return (value & 1) === 1;
}

function findTagIdentityField() {
    const maxOffset = Math.min(tagASize, tagBSize, 0x80);
    for (let offset = 8; offset < maxOffset; offset += 4) {
        const tagAIdentity = read32(tagAOffset + offset) >>> 0;
        const tagBIdentity = read32(tagBOffset + offset) >>> 0;
        if (!isTaggedReference(tagAIdentity) || !isTaggedReference(tagBIdentity)) continue;
        if (tagAIdentity === tagBIdentity) continue;

        const tagAIndex = read32((tagAIdentity - 1) + 4) >>> 1;
        const tagBIndex = read32((tagBIdentity - 1) + 4) >>> 1;
        if (tagAIndex === 0 && tagBIndex === 1) {
            return { offset, tagAIdentity, tagBIdentity };
        }
    }

    guardTools.fail("Harness error: could not locate the WebAssembly.Tag identity field.");
}

const identityField = findTagIdentityField();
const readableRanges = Object.freeze([
    [tagAOffset, tagAOffset + tagASize],
    [tagBOffset, tagBOffset + tagBSize],
    [identityField.tagAIdentity - 1, identityField.tagAIdentity - 1 + 0x20],
    [identityField.tagBIdentity - 1, identityField.tagBIdentity - 1 + 0x20],
]);

function normalizeRange(offset, size) {
    const normalizedOffset = guardTools.normalizeNumber(offset, "Sandbox.MemoryView offset");
    const normalizedSize = guardTools.normalizeNumber(size, "Sandbox.MemoryView size");
    if (normalizedSize <= 0 || normalizedSize > 8) {
        guardTools.fail("Use small MemoryView windows for this ramp.");
    }
    return [normalizedOffset, normalizedOffset + normalizedSize];
}

function isInsideAllowedRange(start, end) {
    return readableRanges.some(([rangeStart, rangeEnd]) => start >= rangeStart && end <= rangeEnd);
}

function tagIdentityCopied() {
    return (read32(tagBOffset + identityField.offset) >>> 0) === identityField.tagAIdentity;
}

function requireTagIdentityCopied() {
    if (!tagIdentityCopied()) {
        guardTools.fail("Copy tagA's identity field into tagB before using the imported-tag native probe.");
    }
}

function instantiateImportedTagNativeProbe(firstTag, secondTag) {
    guardTools.requireSameObject(firstTag, tagA, "Instantiate the native probe with tagA first.");
    guardTools.requireSameObject(secondTag, tagB, "Instantiate the native probe with tagB second.");
    requireTagIdentityCopied();

    let exports;
    try {
        exports = new WebAssembly.Instance(
            new WebAssembly.Module(importedTagNativeProbeBytes),
            { m: { tagA: firstTag, tagB: secondTag } },
        ).exports;
    } catch (error) {
        guardTools.fail(`The imported-tag native probe did not instantiate: ${error}`);
    }

    activeProbe = exports;
    return Object.freeze({
        initProofBox() {
            initializedProofBox = true;
            exports.init_box(initialProofValue);
        },
        leakProofBoxPointer() {
            leakedProofBox = true;
            proofBoxPointer = BigInt(exports.leak_box_ptr());
            return proofBoxPointer;
        },
        nativeWrite32(address, value) {
            nativeWriteCalls++;
            exports.native_write32(BigInt(address), value >>> 0);
        },
    });
}

function getImportedTagNativeProbe() {
    if (activeProbeWrapper === undefined) {
        activeProbeWrapper = instantiateImportedTagNativeProbe(tagA, tagB);
    }
    return activeProbeWrapper;
}

function leakProofBoxPointer() {
    const probe = getImportedTagNativeProbe();
    probe.initProofBox();
    leakHelperUsed = true;
    return probe.leakProofBoxPointer();
}

function nativeWrite32(address, value) {
    if (!leakHelperUsed || proofBoxPointer === undefined) {
        guardTools.fail("Use leakProofBoxPointer() before nativeWrite32(address, value).");
    }
    const normalizedAddress = BigInt(address);
    if (derivedProofFieldAddress === undefined || normalizedAddress !== derivedProofFieldAddress) {
        guardTools.fail("Write to the proof-field address returned by proofFieldAddressFromTaggedBoxPointer().");
    }
    if ((value >>> 0) !== expectedToken) {
        guardTools.fail("Write expectedToken to the proof field.");
    }
    return getImportedTagNativeProbe().nativeWrite32(normalizedAddress, value);
}

function proofFieldAddressFromTaggedBoxPointer(taggedPointer) {
    if (!leakHelperUsed || !leakedProofBox || proofBoxPointer === undefined) {
        guardTools.fail("Leak the proof box pointer before deriving its proof-field address.");
    }

    const normalizedPointer = BigInt(taggedPointer);
    if (normalizedPointer !== proofBoxPointer) {
        guardTools.fail("Derive the proof-field address from the leaked proof-box pointer.");
    }

    derivedProofFieldAddress = normalizedPointer + proofFieldDelta;
    return derivedProofFieldAddress;
}

const sandboxRules = Object.freeze({
    getAddressOf(object) {
        if (object === tagA) return tagAOffset;
        if (object === tagB) return tagBOffset;
        guardTools.fail("Wrong object: this ramp only exposes tagA and tagB.");
    },
    getSizeOf(object) {
        if (object === tagA) return tagASize;
        if (object === tagB) return tagBSize;
        guardTools.fail("Wrong object: this ramp only exposes tagA and tagB sizes.");
    },
    MemoryView(offset, size) {
        const [start, end] = normalizeRange(offset, size);
        if (!isInsideAllowedRange(start, end)) {
            guardTools.fail("This ramp only allows MemoryView access to the tag wrappers and their tag identities.");
        }
        return new guardTools.realSandbox.MemoryView(start, end - start);
    },
});
{% endblock %}

{% block expose %}
guardTools.exposeConstant("tagA", tagA);
guardTools.exposeConstant("tagB", tagB);
guardTools.exposeConstant("leakProofBoxPointer", leakProofBoxPointer);
guardTools.exposeConstant("nativeWrite32", nativeWrite32);
guardTools.exposeConstant("expectedToken", expectedToken);
guardTools.exposeConstant("proofFieldAddressFromTaggedBoxPointer", proofFieldAddressFromTaggedBoxPointer);
{% endblock %}

{% block validate %}
if (activeProbe === undefined) {
    guardTools.fail("Use leakProofBoxPointer() to prepare the imported-tag native probe.");
}
if (!tagIdentityCopied()) {
    guardTools.fail("Copy tagA's identity field into tagB.");
}
if (!initializedProofBox) {
    guardTools.fail("Use leakProofBoxPointer() to initialize and leak the proof box.");
}
if (!leakHelperUsed || !leakedProofBox || proofBoxPointer === undefined) {
    guardTools.fail("Use leakProofBoxPointer() to get the tagged proof-box pointer.");
}
if (nativeWriteCalls === 0) {
    guardTools.fail("Use nativeWrite32(address, value) to mutate the proof field.");
}

const proofValue = activeProbe.native_read32(proofBoxPointer + proofFieldDelta) >>> 0;
if (proofValue === initialProofValue) {
    guardTools.fail("The proof box field is still unchanged.");
}
if (proofValue !== expectedToken) {
    guardTools.fail(`The proof box field is 0x${proofValue.toString(16)}, not expectedToken.`);
}
return true;
{% endblock %}

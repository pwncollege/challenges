{% extends "../../../common/sandbox-guard-harness.js.j2" %}

{% block setup %}
const expectedToken = 0x5a17c0de;
const tagHandlerProbeBytes = new Uint8Array([
    0, 97, 115, 109, 1, 0, 0, 0, 1, 27, 7, 96, 1, 127, 0, 96,
    1, 127, 0, 96, 0, 0, 93, 2, 96, 0, 0, 96, 0, 2, 127, 100,
    3, 96, 0, 1, 127, 2, 21, 2, 1, 109, 4, 116, 97, 103, 65,
    4, 0, 0, 1, 109, 4, 116, 97, 103, 66, 4, 0, 1, 3, 3, 2,
    4, 6, 7, 15, 1, 11, 99, 97, 116, 99, 104, 95, 116, 111, 107,
    101, 110, 0, 1, 9, 5, 1, 3, 0, 1, 0, 10, 30, 2, 10, 0,
    65, 222, 129, 223, 208, 5, 226, 0, 11, 17, 0, 2, 5, 210,
    0, 224, 3, 227, 3, 1, 0, 1, 0, 0, 11, 26, 11, 0, 32, 4,
    110, 97, 109, 101, 1, 25, 2, 0, 9, 115, 117, 115, 112, 101,
    110, 100, 101, 114, 1, 11, 99, 97, 116, 99, 104, 95, 116, 111,
    107, 101, 110,
]);

const tagA = new WebAssembly.Tag({ parameters: ["i32"] });
const tagB = new WebAssembly.Tag({ parameters: ["i32"] });
const tagAOffset = guardTools.realSandbox.getAddressOf(tagA);
const tagBOffset = guardTools.realSandbox.getAddressOf(tagB);
const tagASize = guardTools.realSandbox.getSizeOf(tagA);
const tagBSize = guardTools.realSandbox.getSizeOf(tagB);
let probeInstantiated = false;
let handlerCalled = false;
let lastHandlerToken;

function read32(offset) {
    return guardTools.readUint32(offset);
}

function isTaggedReference(value) {
    return (value & 1) === 1;
}

function findTagIdentityField() {
    const maxOffset = Math.min(tagASize, tagBSize, 0x80);
    for (let offset = 8; offset < maxOffset; offset += 4) {
        const tagAIdentity = read32(tagAOffset + offset) >>> 0;
        const tagBIdentity = read32(tagBOffset + offset) >>> 0;
        if (!isTaggedReference(tagAIdentity) || !isTaggedReference(tagBIdentity)) continue;
        if (tagAIdentity === tagBIdentity) continue;

        const tagAMap = read32(tagAIdentity - 1) >>> 0;
        const tagBMap = read32(tagBIdentity - 1) >>> 0;
        const tagAHeader = read32((tagAIdentity - 1) + 4) >>> 0;
        const tagBHeader = read32((tagBIdentity - 1) + 4) >>> 0;
        if (tagAMap === tagBMap && tagAHeader === tagBHeader) {
            return { offset, tagAIdentity, tagBIdentity };
        }
    }

    guardTools.fail("Harness error: could not locate the WebAssembly.Tag identity field.");
}

const identityField = findTagIdentityField();
const readableRanges = Object.freeze([
    [tagAOffset, tagAOffset + tagASize],
    [tagBOffset, tagBOffset + tagBSize],
    [identityField.tagAIdentity - 1, identityField.tagAIdentity - 1 + 0x20],
    [identityField.tagBIdentity - 1, identityField.tagBIdentity - 1 + 0x20],
]);

function normalizeRange(offset, size) {
    const normalizedOffset = guardTools.normalizeNumber(offset, "Sandbox.MemoryView offset");
    const normalizedSize = guardTools.normalizeNumber(size, "Sandbox.MemoryView size");
    if (normalizedSize <= 0 || normalizedSize > 8) {
        guardTools.fail("Use small MemoryView windows for this ramp.");
    }
    return [normalizedOffset, normalizedOffset + normalizedSize];
}

function isInsideAllowedRange(start, end) {
    return readableRanges.some(([rangeStart, rangeEnd]) => start >= rangeStart && end <= rangeEnd);
}

function tagIdentityCopied() {
    return (read32(tagBOffset + identityField.offset) >>> 0) === identityField.tagAIdentity;
}

function requireTagIdentityCopied() {
    if (!tagIdentityCopied()) {
        guardTools.fail("Copy tagA's identity field into tagB before instantiating the imported-tag probe.");
    }
}

function instantiateImportedTagProbe(firstTag, secondTag) {
    guardTools.requireSameObject(firstTag, tagA, "Instantiate the probe with the provided tagA as the first tag.");
    guardTools.requireSameObject(secondTag, tagB, "Instantiate the probe with the provided tagB as the second tag.");
    requireTagIdentityCopied();

    let instance;
    try {
        instance = new WebAssembly.Instance(
            new WebAssembly.Module(tagHandlerProbeBytes),
            { m: { tagA: firstTag, tagB: secondTag } },
        );
    } catch (error) {
        guardTools.fail(`The WasmFX imported-tag probe did not instantiate: ${error}`);
    }

    probeInstantiated = true;
    return Object.freeze({
        catchToken() {
            handlerCalled = true;
            try {
                lastHandlerToken = instance.exports.catch_token() >>> 0;
                return lastHandlerToken;
            } catch (error) {
                guardTools.fail(`The imported tag handler did not catch the suspension: ${error}`);
            }
        },
    });
}

const sandboxRules = Object.freeze({
    getAddressOf(object) {
        if (object === tagA) return tagAOffset;
        if (object === tagB) return tagBOffset;
        guardTools.fail("Wrong object: this ramp only exposes tagA and tagB.");
    },
    getSizeOf(object) {
        if (object === tagA) return tagASize;
        if (object === tagB) return tagBSize;
        guardTools.fail("Wrong object: this ramp only exposes tagA and tagB sizes.");
    },
    MemoryView(offset, size) {
        const [start, end] = normalizeRange(offset, size);
        if (!isInsideAllowedRange(start, end)) {
            guardTools.fail("This ramp only allows MemoryView access to the tag wrappers and their tag identities.");
        }
        return new guardTools.realSandbox.MemoryView(start, end - start);
    },
});
{% endblock %}

{% block expose %}
guardTools.exposeConstant("tagA", tagA);
guardTools.exposeConstant("tagB", tagB);
guardTools.exposeConstant("instantiateImportedTagProbe", instantiateImportedTagProbe);
{% endblock %}

{% block validate %}
if (!probeInstantiated) {
    guardTools.fail("Instantiate the imported-tag WasmFX probe.");
}
if (!tagIdentityCopied()) {
    guardTools.fail("Copy tagA's identity field into tagB.");
}
if (!handlerCalled) {
    guardTools.fail("Call catchToken() on the imported-tag probe.");
}
if (typeof handlerToken === "undefined") {
    guardTools.fail("Store the handler result in handlerToken.");
}
if ((handlerToken >>> 0) !== lastHandlerToken) {
    guardTools.fail("handlerToken does not match the value returned by catchToken().");
}
if (lastHandlerToken !== expectedToken) {
    guardTools.fail(`catchToken() returned 0x${lastHandlerToken.toString(16)}, not the expected confused-handler token.`);
}
return true;
{% endblock %}

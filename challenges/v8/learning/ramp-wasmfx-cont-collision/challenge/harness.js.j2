{% extends "../../../common/sandbox-guard-harness.js.j2" %}

{% block setup %}
const expectedToken = 0x5a17c0de;
const continuationProbeBytes = new Uint8Array([
    0, 97, 115, 109, 1, 0, 0, 0, 1, 59, 12, 95, 1, 127, 1, 96,
    0, 2, 126, 99, 0, 96, 0, 2, 100, 0, 126, 93, 1, 93, 2, 95,
    1, 100, 3, 1, 95, 1, 100, 4, 1, 96, 1, 127, 1, 100, 0,
    96, 1, 100, 0, 1, 127, 96, 0, 1, 100, 5, 96, 0, 1, 100,
    6, 96, 1, 100, 5, 1, 126, 3, 8, 7, 1, 2, 7, 8, 9, 10,
    11, 6, 7, 1, 99, 0, 1, 208, 0, 11, 7, 82, 6, 4, 103, 66,
    111, 120, 3, 0, 8, 105, 110, 105, 116, 95, 98, 111, 120, 0,
    2, 8, 114, 101, 97, 100, 95, 98, 111, 120, 0, 3, 16, 109,
    97, 107, 101, 95, 108, 101, 97, 107, 95, 115, 116, 97, 116, 105,
    99, 0, 4, 16, 109, 97, 107, 101, 95, 108, 101, 97, 107, 95,
    97, 99, 116, 117, 97, 108, 0, 5, 11, 114, 101, 115, 117, 109,
    101, 95, 108, 101, 97, 107, 0, 6, 9, 6, 1, 3, 0, 2, 0,
    1, 10, 75, 7, 6, 0, 66, 0, 208, 0, 11, 7, 0, 35, 0,
    212, 66, 0, 11, 16, 1, 1, 100, 0, 32, 0, 251, 0, 0, 34,
    1, 36, 0, 32, 1, 11, 8, 0, 32, 0, 251, 2, 0, 0, 11,
    9, 0, 210, 0, 224, 3, 251, 0, 5, 11, 9, 0, 210, 1, 224,
    4, 251, 0, 6, 11, 12, 0, 32, 0, 251, 2, 5, 0, 227, 3,
    0, 26, 11, 0, 109, 4, 110, 97, 109, 101, 1, 102, 7, 0, 17,
    108, 101, 97, 107, 95, 115, 116, 97, 116, 105, 99, 95, 100, 117,
    109, 109, 121, 1, 11, 108, 101, 97, 107, 95, 97, 99, 116, 117,
    97, 108, 2, 8, 105, 110, 105, 116, 95, 98, 111, 120, 3, 8,
    114, 101, 97, 100, 95, 98, 111, 120, 4, 16, 109, 97, 107, 101,
    95, 108, 101, 97, 107, 95, 115, 116, 97, 116, 105, 99, 5, 16,

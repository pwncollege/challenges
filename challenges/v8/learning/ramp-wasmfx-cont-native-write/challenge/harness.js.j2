    }
}

function findWriteContinuationField() {
    requireWriteBoxes();
    if (writeContinuationField === undefined) {
        writeContinuationField = findContinuationField(writeStaticBox, writeActualBox);
    }
    return writeContinuationField;
}

function refreshWriteContinuationField() {
    if (writeStaticBox !== undefined && writeActualBox !== undefined && writeContinuationField === undefined) {
        findWriteContinuationField();
    }
}

function readableRanges() {
    requireWriteBoxes();
    const staticOffset = guardTools.realSandbox.getAddressOf(writeStaticBox);
    const actualOffset = guardTools.realSandbox.getAddressOf(writeActualBox);
    return [
        [staticOffset, staticOffset + guardTools.realSandbox.getSizeOf(writeStaticBox)],
        [actualOffset, actualOffset + guardTools.realSandbox.getSizeOf(writeActualBox)],
    ];
}

function normalizeRange(offset, size) {
    const normalizedOffset = guardTools.normalizeNumber(offset, "Sandbox.MemoryView offset");
    const normalizedSize = guardTools.normalizeNumber(size, "Sandbox.MemoryView size");
    if (normalizedSize <= 0 || normalizedSize > 8) {
        guardTools.fail("Use small MemoryView windows for this ramp.");
    }
    return [normalizedOffset, normalizedOffset + normalizedSize];
}

function isInsideAllowedRange(start, end) {
    return readableRanges().some(([rangeStart, rangeEnd]) => start >= rangeStart && end <= rangeEnd);
}

const sandboxRules = Object.freeze({
    getAddressOf(object) {
        requireWriteBoxes();
        if (object === writeStaticBox) return guardTools.realSandbox.getAddressOf(object);
        if (object === writeActualBox) return guardTools.realSandbox.getAddressOf(object);
        guardTools.fail("Only the allocated write continuation boxes are addressable in this ramp.");
    },
    getSizeOf(object) {
        requireWriteBoxes();
        if (object === writeStaticBox) return guardTools.realSandbox.getSizeOf(object);
        if (object === writeActualBox) return guardTools.realSandbox.getSizeOf(object);
        guardTools.fail("Only the allocated write continuation boxes have exposed sizes in this ramp.");
    },
    MemoryView(offset, size) {
        const [start, end] = normalizeRange(offset, size);
        if (!isInsideAllowedRange(start, end)) {

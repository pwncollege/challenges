    return writeStaticBox;
}

function makeWriteActualBox() {
    if (writeActualBox === undefined) {
        writeActualBox = keep(fx.make_write_actual());
    }
    refreshWriteContinuationField();
    return writeActualBox;
}

function resumeWrite(staticBox, forgedReferenceValue, value) {
    initProofBox();
    const normalizedReference = BigInt(forgedReferenceValue);
    if (derivedForgedReference === undefined || normalizedReference !== derivedForgedReference) {
        guardTools.fail("Pass the reference returned by forgedReferenceForFieldAddress(address) to resumeWrite().");
    }
    if ((value >>> 0) !== expectedToken) {
        guardTools.fail("Write expectedToken to the proof field.");
    }
    fx.set_write_value(value >>> 0);
    writeResumed = true;
    try {

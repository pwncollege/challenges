{% block validate %}
if (proofBox === undefined) {
    guardTools.fail("Initialize the proof box.");
}
if (!leakHelperUsed || lastLeakResult === undefined) {
    guardTools.fail("Use leakProofBoxPointer() to get the tagged proof-box pointer.");
}
const writeField = findWriteContinuationField();
const writeContinuationNow = read32(writeField.expectedOffset + writeField.offset) >>> 0;
if (writeContinuationNow === writeField.expectedContinuation) {
    guardTools.fail("The write static continuation box still points at its original continuation.");
}
if (writeContinuationNow !== writeField.actualContinuation) {
    guardTools.fail("The write static continuation box does not contain the actual continuation reference.");
}
if (!writeResumed) {
    guardTools.fail("Use the write continuation pair to mutate the proof field.");
}

const proofValue = readProofBox();
if (proofValue === initialProofValue) {
    guardTools.fail("The proof box field is still unchanged.");
}
if (proofValue !== expectedToken) {
    guardTools.fail(`The proof box field is 0x${proofValue.toString(16)}, not expectedToken.`);
}
return true;

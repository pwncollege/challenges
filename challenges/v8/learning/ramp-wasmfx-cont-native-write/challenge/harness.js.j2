});

function forgedReferenceForFieldAddress(address) {
    const normalizedAddress = BigInt(address);
    if (derivedProofFieldAddress === undefined || normalizedAddress !== derivedProofFieldAddress) {
        guardTools.fail("Use the proof-field address returned by proofFieldAddressFromTaggedBoxPointer().");
    }
    derivedForgedReference = normalizedAddress - proofFieldDelta;
    return derivedForgedReference;
}

function proofFieldAddressFromTaggedBoxPointer(taggedPointer) {
    if (!leakHelperUsed || lastLeakResult === undefined) {
        guardTools.fail("Leak the proof box pointer before deriving its proof-field address.");
    }

    const normalizedPointer = BigInt(taggedPointer);
    if (normalizedPointer !== lastLeakResult) {
        guardTools.fail("Derive the proof-field address from the leaked proof-box pointer.");
    }

    derivedProofFieldAddress = normalizedPointer + proofFieldDelta;
    return derivedProofFieldAddress;
}

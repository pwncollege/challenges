const fx = new WebAssembly.Instance(new WebAssembly.Module(continuationNativeProbeBytes), {}).exports;
let proofBox;
const keepAlive = [];
let leakResumed = false;
let lastLeakResult;
let leakStaticBox;
let leakActualBox;
let leakContinuationField;

function read32(offset) {
    return guardTools.readUint32(offset);
}

function write32(offset, value) {
    guardTools.writeUint32(offset, value >>> 0);
}

function initProofBox() {
    if (proofBox === undefined) {
        proofBox = fx.init_box(initialProofValue);
        keepAlive.push(proofBox);
    }
    return proofBox;
}

function keep(object) {
    keepAlive.push(object);
    return object;
}

function findContinuationField(expectedBox, actualBox) {
    const expectedOffset = guardTools.realSandbox.getAddressOf(expectedBox);
    const actualOffset = guardTools.realSandbox.getAddressOf(actualBox);
    const expectedSize = guardTools.realSandbox.getSizeOf(expectedBox);
    const actualSize = guardTools.realSandbox.getSizeOf(actualBox);
    const maxOffset = Math.min(expectedSize, actualSize, 0x80);

    for (let offset = 8; offset < maxOffset; offset += 4) {
        const expectedContinuation = read32(expectedOffset + offset) >>> 0;
        const actualContinuation = read32(actualOffset + offset) >>> 0;
        if ((expectedContinuation & 1) === 1 && (actualContinuation & 1) === 1 && expectedContinuation !== actualContinuation) {
            return { offset, expectedOffset, actualOffset, expectedContinuation, actualContinuation };
        }
    }

    guardTools.fail("Could not find distinct continuation references in those boxes.");
}

function requireLeakBoxes() {
    if (leakStaticBox === undefined || leakActualBox === undefined) {
        guardTools.fail("Allocate both leak continuation boxes before using the guarded Sandbox APIs.");
    }
}

function findLeakContinuationField() {
    requireLeakBoxes();
    if (leakContinuationField === undefined) {
        leakContinuationField = findContinuationField(leakStaticBox, leakActualBox);
    }
    return leakContinuationField;
}

function refreshLeakContinuationField() {
    if (leakStaticBox !== undefined && leakActualBox !== undefined && leakContinuationField === undefined) {
        findLeakContinuationField();
    }
}

function makeLeakStaticBox() {
    if (leakStaticBox === undefined) {
        leakStaticBox = keep(fx.make_leak_static());
    }
    refreshLeakContinuationField();
    return leakStaticBox;
}

function makeLeakActualBox() {
    if (leakActualBox === undefined) {
        leakActualBox = keep(fx.make_leak_actual());
    }
    refreshLeakContinuationField();
    return leakActualBox;
}

function resumeLeak(staticBox) {
    leakResumed = true;
    try {
        lastLeakResult = BigInt(fx.resume_leak(staticBox));
        return lastLeakResult;
    } catch (error) {
        guardTools.fail(`The leak continuation did not resume cleanly: ${error}`);
    }
}

function readableRanges() {
    requireLeakBoxes();
    const staticOffset = guardTools.realSandbox.getAddressOf(leakStaticBox);
    const actualOffset = guardTools.realSandbox.getAddressOf(leakActualBox);
    return [
        [staticOffset, staticOffset + guardTools.realSandbox.getSizeOf(leakStaticBox)],
        [actualOffset, actualOffset + guardTools.realSandbox.getSizeOf(leakActualBox)],
    ];
}

function normalizeRange(offset, size) {
    const normalizedOffset = guardTools.normalizeNumber(offset, "Sandbox.MemoryView offset");
    const normalizedSize = guardTools.normalizeNumber(size, "Sandbox.MemoryView size");
    if (normalizedSize <= 0 || normalizedSize > 8) {
        guardTools.fail("Use small MemoryView windows for this ramp.");
    }
    return [normalizedOffset, normalizedOffset + normalizedSize];
}

function isInsideAllowedRange(start, end) {
    return readableRanges().some(([rangeStart, rangeEnd]) => start >= rangeStart && end <= rangeEnd);
}

const sandboxRules = Object.freeze({
    getAddressOf(object) {
        requireLeakBoxes();
        if (object === leakStaticBox) return guardTools.realSandbox.getAddressOf(object);
        if (object === leakActualBox) return guardTools.realSandbox.getAddressOf(object);
        guardTools.fail("Only the allocated leak continuation boxes are addressable in this ramp.");
    },
    getSizeOf(object) {
        requireLeakBoxes();
        if (object === leakStaticBox) return guardTools.realSandbox.getSizeOf(object);
        if (object === leakActualBox) return guardTools.realSandbox.getSizeOf(object);
        guardTools.fail("Only the allocated leak continuation boxes have exposed sizes in this ramp.");
    },
    MemoryView(offset, size) {
        const [start, end] = normalizeRange(offset, size);
        if (!isInsideAllowedRange(start, end)) {
            guardTools.fail("This ramp only allows MemoryView access to the two leak continuation boxes.");
        }
        return new guardTools.realSandbox.MemoryView(start, end - start);
    },
    disabledMessages: {
        getObjectAt: "Object fabrication is not part of this ramp.",
    },
});


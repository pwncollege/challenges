{% block validate %}
if (proofBox === undefined) {
    guardTools.fail("Initialize the proof box.");
}
requireLeakBoxes();
const leakField = findLeakContinuationField();
const leakContinuationNow = read32(leakField.expectedOffset + leakField.offset) >>> 0;
if (leakContinuationNow === leakField.expectedContinuation) {
    guardTools.fail("The leak static continuation box still points at its original continuation.");
}
if (leakContinuationNow !== leakField.actualContinuation) {
    guardTools.fail("The leak static continuation box does not contain the actual continuation reference.");
}
if (!leakResumed) {
    guardTools.fail("Use the leak continuation pair to obtain the proof box pointer.");
}
if (typeof leakedProofBoxPointer === "undefined") {
    guardTools.fail("Store the leaked pointer in leakedProofBoxPointer.");
}
if (BigInt(leakedProofBoxPointer) !== lastLeakResult) {
    guardTools.fail("leakedProofBoxPointer does not match the continuation leak result.");
}
if ((lastLeakResult & 1n) !== 1n) {
    guardTools.fail("The leaked proof-box pointer should still be a tagged reference.");
}
return true;

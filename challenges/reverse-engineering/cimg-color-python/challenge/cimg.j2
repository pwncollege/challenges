{%- import "../../common/cimg_lib.j2" as lib -%}
{%- set c = namespace() -%}
{{- lib.defaults(c, "color") -}}
{{- lib.draw_magic(c, random, false) -}}
{%- set c.version = 2 -%}
{%- set c.version_bitwidth = random.choice([8, 16, 32, 64]) -%}
{%- set c.has_dims = true -%}
{%- set c.dims_checked = true -%}
{%- set c.read_data = true -%}
{%- set c.assert_ascii = true -%}
{%- set c.display = true -%}
{%- set c.color = true -%}
{%- set c.width = random.randint(20, 80) -%}
{%- set c.height = random.randint(20, 24) -%}
{%- set c.width_bitwidth = random.choice([8, 16, 32, 64]) -%}
{%- set c.height_bitwidth = random.choice([8, 16, 32, 64]) -%}
{%- set c.check_asu_maroon = true -%}
{%- set c.check_num_nonspace = c.width * c.height -%}
{%- include "../../common/cimg_body.py.j2" -%}

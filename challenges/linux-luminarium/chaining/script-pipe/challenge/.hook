#!/bin/bash

unset BASH_ENV

if ! /challenge/.check_redir
then
	fold -s <<< "It looks like you are not piping this script out to /challenge/solve! Remember to pipe the output of your script into /challenge/solve using '|'." > /dev/tty
	exit 1
fi

if [ ! -r /tmp/.pwn-secret ]
then
	fold -s <<< "The challenge secret was not initialized. Run your script from the challenge shell with bash, then pipe it to /challenge/solve." > /dev/tty
	exit 1
fi

cp /tmp/.pwn-secret "/tmp/.pwn-script-pipe-ready.$$"

#!/usr/bin/exec-suid -- /bin/bash -p

function check_script_parent {
	local parent_exe
	parent_exe="$(readlink -f "/proc/$PPID/exe")" || return 1

	if [ "${parent_exe##*/}" != "bash" ]
	then
		return 1
	fi

	local -a parent_cmdline
	mapfile -d '' -t parent_cmdline < "/proc/$PPID/cmdline" || return 1
	[ "${#parent_cmdline[@]}" -eq 2 ] && [[ "${parent_cmdline[1]}" == *.sh ]]
}

if ! check_script_parent
then
	fold -s >&2 <<< "It looks like /challenge/pwn is not running from a script launched with bash and piped to /challenge/solve."
	exit 1
fi

if [ ! -r /tmp/.pwn-secret ]
then
	fold -s >&2 <<< "The challenge secret was not initialized. Run your script from the challenge shell with bash, then pipe it to /challenge/solve."
	exit 1
fi

(
	head -c 16 /flag
	cat /tmp/.pwn-secret
) | md5sum

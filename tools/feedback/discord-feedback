def relpath(path: pathlib.Path, repo: pathlib.Path) -> str:
    try:
        return path.resolve().relative_to(repo.resolve()).as_posix()
    except ValueError:
        return path.as_posix()


def read_text_if_exists(path: pathlib.Path) -> str:
    if not path.exists():
        return ""
    return path.read_text(errors="replace")


def first_line_after_heading(text: str, heading: str) -> Optional[str]:
    in_section = False
    marker = f"## {heading}".lower()
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.lower() == marker:
            in_section = True
            continue
        if not in_section or not stripped:
            continue
        if stripped.startswith("#"):
            return None
        return ellipsize(stripped, 260)
    return None


def markdown_headings(text: str, *, limit: int = 8) -> list[str]:
    headings: list[str] = []
    for line in text.splitlines():
        stripped = line.strip()
        if not stripped.startswith("##"):
            continue
        title = stripped.lstrip("#").strip()
        lowered = title.lower()
        if lowered in {"verdict", "files changed"}:
            continue
        if lowered.startswith("changed paths"):
            continue
        if lowered.startswith("recommended validation"):
            continue
        headings.append(ellipsize(title, 220))
        if len(headings) >= limit:
            break
    return headings


def test_log_summary(test_log: pathlib.Path) -> str:
    text = read_text_if_exists(test_log)
    if not text:
        return f"Validation log was not found at `{test_log}`."

    for line in reversed(text.splitlines()):
        stripped = line.strip()
        if not stripped:
            continue
        if (
            "all tests passed" in stripped.lower()
            or "tests failed" in stripped.lower()
            or "failed" in stripped.lower()
        ):
            return stripped
    return "Validation log was captured, but no final pass/fail summary was found."


def git_diff_stat(repo: pathlib.Path, base_ref: str, *, max_lines: int = 24) -> str:
    try:
        stat = git_output(["diff", "--stat", base_ref, "--"], repo)
    except subprocess.CalledProcessError:
        return ""
    lines = stat.strip().splitlines()
    if len(lines) > max_lines:
        hidden = len(lines) - max_lines
        lines = [*lines[:max_lines], f"... ({hidden} more stat lines)"]
    return "\n".join(lines)


def pr_body_is_usable(body: str) -> bool:
    lowered = body.lower()
    forbidden = [
        "pr body written to",
        "it covers",
        "structure:",
        "one judgment call:",
        "deferred larger design",
        "larger design items",
        "needs design",
        "the **validation** section",
        "the **summary** section",
    ]
    if any(marker in lowered for marker in forbidden):
        return False
    required = [
        "## summary",
        "## validation",
        "## notes / deferred follow-ups",
    ]
    return all(marker in lowered for marker in required)


def build_fallback_pr_body(
    repo: pathlib.Path,
    base_ref: str,
    analysis_path: pathlib.Path,
    implementation_notes: pathlib.Path,
    ux_review: pathlib.Path,
    test_log: pathlib.Path,
) -> str:
    implementation_text = read_text_if_exists(implementation_notes)
    ux_text = read_text_if_exists(ux_review)
    validation_line = test_log_summary(test_log)
    stat = git_diff_stat(repo, base_ref)

    implementation_headings = markdown_headings(implementation_text, limit=8)
    ux_headings = markdown_headings(ux_text, limit=8)
    summary_lines = [
        heading
        for heading in implementation_headings
        if not any(
            marker in heading.lower()
            for marker in [
                "already merged",
                "no repo change",
                "not changed",
                "unrelated working-tree",
            ]
        )
    ][:4]
    summary_lines.extend(
        heading
        for heading in ux_headings
        if not heading.lower().startswith(("fixed", "checked", "observations"))
    )
    summary_lines = summary_lines[:5]
    if not summary_lines:
        summary_lines = []

    ux_verdict = first_line_after_heading(ux_text, "Verdict")
    notes_lines = [
        heading
        for heading in implementation_headings
        if any(
            marker in heading.lower()
            for marker in [
                "already merged",
                "no repo change",
                "not changed",
                "deferred",
                "unrelated working-tree",
            ]
        )
    ]
    notes_lines.extend(
        heading
        for heading in ux_headings
        if heading.lower().startswith(("observations", "checked"))
    )

    body: list[str] = [
        "## Summary",
        "",
        "- Addresses feedback collected from sanitized public Discord messages.",
    ]
    for line in summary_lines:
        body.append(f"- {line}")

    if stat:
        body.extend(["", "Changed file summary:", "", "```", stat, "```"])

    body.extend(
        [
            "",
            "## Validation",
            "",
            f"- {validation_line} (`{relpath(test_log, repo)}`)",
        ]
    )
    if ux_verdict:
        body.append(f"- UX review: {ux_verdict}")
    elif ux_text:
        body.append(f"- UX review captured in `{relpath(ux_review, repo)}`.")

    body.extend(
        [
            "",
            "## Notes / deferred follow-ups",
            "",
            f"- Analysis artifact: `{relpath(analysis_path, repo)}`",
            f"- Implementation notes: `{relpath(implementation_notes, repo)}`",
            f"- UX review: `{relpath(ux_review, repo)}`",
        ]
    )
    for line in notes_lines[:3]:
        body.append(f"- {line}")

    return "\n".join(body).rstrip() + "\n"


# Set once the run id is known, so any abnormal exit (crash, click error, Ctrl-C) can tell
# the user exactly how to resume. Every phase checkpoints to resume-state.json, so resuming
# never loses work -- the only thing a death used to cost was *knowing* you could resume.
_RESUME_HINT: Optional[str] = None


def _print_resume_hint() -> None:
    if _RESUME_HINT:
        click.echo(_RESUME_HINT, err=True)


_PWNSHOP_PREFIX: Optional[list[str]] = None


def _pwnshop_prefix(repo: pathlib.Path) -> list[str]:
    """Decide how to invoke pwnshop, once per run, and cache it.

    `nix develop --command pwnshop` re-evaluates the flake and always resolves the repo's
    *current* pwnshop, but it's slow, so when we're already inside a dev shell we'd rather
    call the bare `pwnshop` on PATH. The catch: a long-lived dev shell can go stale -- its
    PATH still points at an old-generation pwnshop wrapper whose launcher script no longer
    exists in the checkout, so every `pwnshop ...` exits 127 ("No such file or directory").
    That looks exactly like "all tests failed with no logs", which sends the fix agent
    chasing a phantom breakage until the run dies. So preflight the in-shell pwnshop with a
    cheap `--help`; if it can't even launch, fall back to `nix develop --command` (a fresh
    flake eval) instead of trusting the stale shell.
    """
    global _PWNSHOP_PREFIX
    if _PWNSHOP_PREFIX is not None:
        return _PWNSHOP_PREFIX
    fresh = ["nix", "develop", "--command", "pwnshop"]
    if not os.environ.get("IN_NIX_SHELL"):
        _PWNSHOP_PREFIX = fresh
        return _PWNSHOP_PREFIX
    try:
        probe = subprocess.run(
            ["pwnshop", "--help"],
            cwd=repo,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.PIPE,
            timeout=60,
        )
        ok = probe.returncode == 0
        detail = probe.stderr.decode("utf-8", "replace").strip()
    except (OSError, subprocess.SubprocessError) as error:
        ok = False
        detail = str(error)
    if ok:
        _PWNSHOP_PREFIX = ["pwnshop"]
    else:
        click.echo(
            "Warning: the in-shell `pwnshop` failed to launch "
            f"(stale nix dev shell?): {detail or 'exited nonzero'}. "
            "Falling back to `nix develop --command pwnshop` for this run."
        )
        _PWNSHOP_PREFIX = fresh
    return _PWNSHOP_PREFIX


def pwnshop_invocation(repo: pathlib.Path, args: list[str]) -> list[str]:
    return [*_pwnshop_prefix(repo), *args]


def run_logged(
    command: list[str],
    *,
    cwd: pathlib.Path,
    log_path: pathlib.Path,
    timeout: Optional[int] = None,
) -> int:
    return stream_command(
        command,
        cwd=cwd,
        log_path=log_path,
        timeout=timeout,
        echo_output=True,
        heartbeat_label=pathlib.Path(command[0]).name,
    )


def changed_paths_since(
    repo: pathlib.Path, base_ref: str
) -> set[pathlib.PurePosixPath]:
    diff = git_output(["diff", "--name-only", base_ref, "--", "challenges"], repo)
    paths = {pathlib.PurePosixPath(line) for line in diff.splitlines() if line}
    status = git_output(["status", "--porcelain", "--", "challenges"], repo)
    for line in status.splitlines():
        status_path = line[3:]
        if " -> " in status_path:
            status_path = status_path.split(" -> ", 1)[1]
        if status_path:
            paths.add(pathlib.PurePosixPath(status_path))
    return paths


def changed_challenges_since(repo: pathlib.Path, base_ref: str) -> list[str]:
    challenges: set[str] = set()
    challenges_root = repo / "challenges"
    for path in changed_paths_since(repo, base_ref):
        full_path = repo / path
        candidate = full_path if full_path.is_dir() else full_path.parent
        while candidate != repo and challenges_root in candidate.parents:
            if (candidate / "challenge").is_dir():
                challenges.add(candidate.relative_to(repo).as_posix())
                break
            candidate = candidate.parent
    return sorted(challenges)


def failed_challenges_from_logs(
    repo: pathlib.Path, log_dir: pathlib.Path
) -> list[str]:
    """Map per-challenge failure logs under log_dir back to repo challenge paths.

    `pwnshop test --log-failures` writes a log only for failures, under a tree mirroring
    the repo (``challenges/<...>/<challenge>/{tests_*/<t>.log,_build_error.log}``). Walk up
    from each log to the directory that is a real challenge (has a ``challenge/`` subdir).
    """
    found: set[str] = set()
    for log_file in log_dir.rglob("*.log"):
        candidate = log_file.parent
        while candidate != log_dir:
            rel = candidate.relative_to(log_dir)
            if (repo / rel / "challenge").is_dir():
                found.add(rel.as_posix())
                break
            candidate = candidate.parent
    return sorted(found)


def run_tests(
    repo: pathlib.Path, artifact_dir: pathlib.Path, base_ref: str, attempt: int
) -> pathlib.Path:
    log_dir = artifact_dir / f"test-logs-attempt-{attempt}"
    log_dir.mkdir(parents=True, exist_ok=True)
    test_log = artifact_dir / f"pwnshop-test-attempt-{attempt}.log"
    command = pwnshop_invocation(
        repo,
        [
            "test",
            "--modified-since",
            base_ref,
            "--require-solved",
            "--attempts",
            "2",
            "--log-failures",
            str(log_dir),
            "challenges",
        ],
    )
    rc = run_logged(command, cwd=repo, log_path=test_log)
    if rc == 0:
        return test_log

    # The full validation runs every affected challenge in parallel across all cores. A
    # change to a module's common/ files fans out to the entire module, and timing-sensitive
    # challenges (e.g. the strace/alarm web-server sandbox) flake under that load even though
    # they pass reliably on their own. Before failing the run, re-check just the failed
    # challenges serially (-j1, low load) with extra attempts: a genuinely broken challenge
    # still fails, but a load-induced flake passes and the feedback run continues.
    failed = failed_challenges_from_logs(repo, log_dir)
    if not failed:
        raise click.ClickException(
            f"pwnshop tests failed; see {test_log} and {log_dir}"
        )
    click.echo(
        f"{len(failed)} challenge(s) failed the parallel run; re-checking serially to rule "
        f"out load-induced flakiness: {', '.join(failed)}"
    )
    retry_log_dir = artifact_dir / f"test-logs-attempt-{attempt}-serial"
    retry_log_dir.mkdir(parents=True, exist_ok=True)
    retry_log = artifact_dir / f"pwnshop-test-attempt-{attempt}-serial.log"
    retry_command = pwnshop_invocation(
        repo,
        [
            "test",
            "--require-solved",
            "--attempts",
            "3",
            "--jobs",
            "1",
            "--log-failures",
            str(retry_log_dir),
            *failed,
        ],
    )
    retry_rc = run_logged(retry_command, cwd=repo, log_path=retry_log)
    if retry_rc != 0:
        still_failing = failed_challenges_from_logs(repo, retry_log_dir) or failed
        raise click.ClickException(
            "pwnshop tests failed (confirmed on serial re-run): "
            f"{', '.join(still_failing)}; see {retry_log} and {retry_log_dir}"
        )
    click.echo(
        "Serial re-run of the failed challenge(s) passed; treating the parallel failure(s) "
        "as load-induced flakiness and continuing."
    )
    return test_log


def validate_with_fixes(
    repo: pathlib.Path,
    artifact_dir: pathlib.Path,
    base_ref: str,
    *,
    agent: str,
    analysis_path: pathlib.Path,
    directions: list[str],
    pr_feedback_path: Optional[pathlib.Path],
    first_attempt: int,
    fix_attempts: int,
) -> pathlib.Path:
    """Validate; on a genuine (non-flaky) failure, run the fix agent and retry.

    run_tests already absorbs load-induced flakiness via a serial re-check, so a failure
    that reaches here is a real breakage -- and fixing those agentically is the whole point
    of the bot, not a reason to abort. Each failed attempt feeds the fix agent and re-tests.
    Raises ClickException only if the challenge is still broken after `fix_attempts` fixes.
    """
    for index in range(fix_attempts + 1):
        attempt = first_attempt + index
        click.echo(f"Running pwnshop validation attempt {attempt}")
        try:
            return run_tests(repo, artifact_dir, base_ref, attempt)
        except click.ClickException:
            if index >= fix_attempts:
                raise
            click.echo(f"Validation attempt {attempt} failed; starting fix agent")
            failure_dir = artifact_dir / f"test-logs-attempt-{attempt}"
            run_agent(
                agent,
                build_fix_prompt(
                    analysis_path,
                    failure_dir,
                    attempt,
                    directions,
                    pr_feedback_path,
                ),
                repo=repo,
                artifact_dir=artifact_dir,
                output_name=f"fix-agent-attempt-{attempt}.log",
                apply=True,
            )
    raise AssertionError("unreachable")  # the final attempt returns or raises above


def extract_json_array(text: str) -> list[dict[str, Any]]:
    start = text.find("[")
    end = text.rfind("]")
    if start == -1 or end == -1 or end <= start:
        raise ValueError("no JSON array found")
    parsed = json.loads(text[start : end + 1])
    if not isinstance(parsed, list):
        raise ValueError("playtest plan is not a list")
    return parsed


def safe_title(value: str) -> str:
    value = re.sub(r"[^A-Za-z0-9_.-]+", "-", value.strip()).strip("-")
    digest = hashlib.sha256(value.encode()).hexdigest()[:8]
    return f"{value[:50] or 'cast'}-{digest}"


def run_casts(
    repo: pathlib.Path,
    artifact_dir: pathlib.Path,
    analysis_path: pathlib.Path,
    changed_challenges: list[str],
    agent: str,
    directions: list[str],
) -> pathlib.Path:
    cast_dir = artifact_dir / "casts"
    cast_dir.mkdir(parents=True, exist_ok=True)
    plan_output = run_agent(
        agent,
        build_playtest_plan_prompt(
            analysis_path, changed_challenges, artifact_dir, directions
        ),
        repo=repo,
        artifact_dir=artifact_dir,
        output_name="playtest-plan.raw",
    )
    try:
        plan = extract_json_array(plan_output.read_text())
    except (ValueError, json.JSONDecodeError) as error:
        raise click.ClickException(
            f"Could not parse playtest plan from {plan_output}: {error}"
        ) from error
    (artifact_dir / "playtest-plan.json").write_text(
        json.dumps(plan, indent=2, sort_keys=True) + "\n"
    )

    # Casts are a UX-review aid, not a gate: one bad playtest command (a hang, a nonzero
    # exit) must not abort the whole feedback run. Record every failure and keep going so
    # the cast-review agent still sees the casts that did record.
    failures: list[str] = []
    for index, item in enumerate(plan, start=1):
        challenge = item.get("challenge")
        command = item.get("command")
        if not challenge or not isinstance(command, list):
            message = f"playtest item #{index} is malformed: {item!r}"
            click.echo(f"Skipping {message}")
            failures.append(message)
            continue
        title = safe_title(item.get("title") or pathlib.Path(challenge).name)
        cast_path = cast_dir / f"{index:02d}-{title}.cast"
        log_path = cast_dir / f"{index:02d}-{title}.log"
        click.echo(f"Recording cast {index}/{len(plan)} for {challenge}: {title}")
        pwnshop_args = [
            "run",
            "--cast-to",
            str(cast_path),
            "--timeout",
            str(CAST_TIMEOUT_SECONDS),
            challenge,
            *[str(part) for part in command],
        ]
        try:
            rc = run_logged(
                pwnshop_invocation(repo, pwnshop_args),
                cwd=repo,
                log_path=log_path,
                timeout=CAST_WATCHDOG_SECONDS,
            )
        except subprocess.TimeoutExpired:
            message = (
                f"cast {index} for {challenge} ({title}) wedged past "
                f"{CAST_WATCHDOG_SECONDS}s and was killed; see {log_path}"
            )
        else:
            message = (
                f"cast {index} for {challenge} ({title}) exited {rc}; see {log_path}"
                if rc != 0
                else ""
            )
        if message:
            click.echo(message)
            failures.append(message)

    if failures:
        summary_path = cast_dir / "cast-failures.md"
        summary_path.write_text(
            "# Playtest casts that did not record cleanly\n\n"
            + "\n".join(f"- {line}" for line in failures)
            + "\n"
        )
        click.echo(
            f"{len(failures)}/{len(plan)} playtest cast(s) failed; "
            f"continuing with the rest (details in {summary_path})"
        )
    return cast_dir


def load_watch_state(path: pathlib.Path) -> dict[str, Any]:
    if not path.exists():
        return {
            "batch": 0,
            "handled_events": [],
            "ignored_events": [],
            "replied_events": [],
            "event_responses": {},
            "ci_attempts": {},
        }
    try:
        state = json.loads(path.read_text())
    except json.JSONDecodeError:
        return {
            "batch": 0,
            "handled_events": [],
            "ignored_events": [],
            "replied_events": [],
            "event_responses": {},
            "ci_attempts": {},
        }
    state.setdefault("batch", 0)
    state.setdefault("handled_events", [])
    state.setdefault("ignored_events", [])
    state.setdefault("replied_events", [])
    state.setdefault("event_responses", {})
    state.setdefault("ci_attempts", {})
    return state


def save_watch_state(path: pathlib.Path, state: dict[str, Any]) -> None:
    path.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n")



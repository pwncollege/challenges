class DiscordPermissionError(RuntimeError):
    pass


class DiscordServerError(RuntimeError):
    pass


class GitHubAPIError(RuntimeError):
    def __init__(self, message: str, *, status: Optional[int] = None) -> None:
        super().__init__(message)
        self.status = status


class GitHubNotFound(GitHubAPIError):
    pass


class DiscordAPI:
    def __init__(self, token: str):
        self.token = token

    def request(self, path: str, params: Optional[dict[str, Any]] = None) -> Any:
        query = f"?{urllib.parse.urlencode(params)}" if params else ""
        url = f"{DISCORD_API_BASE}{path}{query}"
        headers = {
            "Authorization": f"Bot {self.token}",
            "User-Agent": "DiscordBot (https://github.com/pwncollege/challenges, pwnshop-feedback)",
            "Content-Type": "application/json",
        }
        request = urllib.request.Request(url, headers=headers)

        server_error_attempts = 0
        while True:
            try:
                with urllib.request.urlopen(request, timeout=30) as response:
                    body = response.read().decode()
                    self._honor_rate_limit_headers(response.headers)
                    return json.loads(body) if body else None
            except urllib.error.HTTPError as error:
                body = error.read().decode(errors="replace")
                if error.code == 429:
                    retry_after = self._retry_after(error.headers, body)
                    logger.info(
                        "Discord rate limit reached; sleeping %.2fs", retry_after
                    )
                    time.sleep(retry_after)
                    continue
                if error.code in {403, 404}:
                    raise DiscordPermissionError(f"{error.code} for {path}") from error
                # Discord 5xx responses are usually transient; back off and retry a
                # bounded number of times before giving up on this request.
                if error.code >= 500:
                    server_error_attempts += 1
                    if server_error_attempts > MAX_DISCORD_SERVER_ERROR_RETRIES:
                        raise DiscordServerError(
                            f"Discord API request failed after "
                            f"{MAX_DISCORD_SERVER_ERROR_RETRIES} retries: "
                            f"{error.code} {path}: {body}"
                        ) from error
                    backoff = min(2**server_error_attempts, 60)
                    logger.warning(
                        "Discord server error %d for %s; retrying in %ds (%d/%d)",
                        error.code,
                        path,
                        backoff,
                        server_error_attempts,
                        MAX_DISCORD_SERVER_ERROR_RETRIES,
                    )
                    time.sleep(backoff)
                    continue
                raise RuntimeError(
                    f"Discord API request failed: {error.code} {path}: {body}"
                ) from error
            except urllib.error.URLError as error:
                # Connection resets and read timeouts are transient too; retry under the
                # same bounded budget so a single network blip can't abort a long scrape.
                server_error_attempts += 1
                if server_error_attempts > MAX_DISCORD_SERVER_ERROR_RETRIES:
                    raise DiscordServerError(
                        f"Discord API request failed after "
                        f"{MAX_DISCORD_SERVER_ERROR_RETRIES} retries: "
                        f"{path}: {error.reason}"
                    ) from error
                backoff = min(2**server_error_attempts, 60)
                logger.warning(
                    "Discord request error for %s (%s); retrying in %ds (%d/%d)",
                    path,
                    error.reason,
                    backoff,
                    server_error_attempts,
                    MAX_DISCORD_SERVER_ERROR_RETRIES,
                )
                time.sleep(backoff)
                continue

    @staticmethod
    def _retry_after(headers: Any, body: str) -> float:
        if headers.get("Retry-After"):
            return float(headers["Retry-After"])
        try:
            parsed = json.loads(body)
        except json.JSONDecodeError:
            return 1.0
        return float(parsed.get("retry_after", 1.0))

    @staticmethod
    def _honor_rate_limit_headers(headers: Any) -> None:
        remaining = headers.get("X-RateLimit-Remaining")
        reset_after = headers.get("X-RateLimit-Reset-After")
        if remaining == "0" and reset_after:
            time.sleep(float(reset_after))


class GitHubAPI:
    def __init__(self, token: str):
        self.token = token
        self._login: Optional[str] = None

    @classmethod
    def from_environment(cls, repo: pathlib.Path) -> "GitHubAPI":
        token = os.environ.get("GH_TOKEN") or os.environ.get("GITHUB_TOKEN")
        if not token and shutil.which("gh"):
            try:
                token = subprocess.check_output(
                    ["gh", "auth", "token"], cwd=repo, text=True
                ).strip()
            except subprocess.CalledProcessError:
                token = ""
        if not token:
            raise click.ClickException(
                "A GitHub token is required for PR watching. "
                "Set GH_TOKEN/GITHUB_TOKEN or authenticate `gh`."
            )
        return cls(token)

    def request(
        self,
        path: str,
        params: Optional[dict[str, Any]] = None,
        *,
        accept: str = "application/vnd.github+json",
    ) -> Any:
        payload, _headers = self._request(path, params=params, accept=accept)
        return payload

    def post(
        self,
        path: str,
        payload: dict[str, Any],
        *,
        accept: str = "application/vnd.github+json",
    ) -> Any:
        response, _headers = self._request(
            path, accept=accept, method="POST", json_body=payload
        )
        return response

    def delete(
        self,
        path: str,
        *,
        accept: str = "application/vnd.github+json",
    ) -> Any:
        response, _headers = self._request(path, accept=accept, method="DELETE")
        return response

    def authenticated_login(self) -> Optional[str]:
        """Login of the token's user, cached. None if it can't be determined."""
        if self._login is None:
            try:
                user = self.request("/user")
                self._login = (user or {}).get("login") or ""
            except GitHubAPIError as error:
                logger.warning("could not determine authenticated GitHub user: %s", error)
                self._login = ""
        return self._login or None

    def request_all(
        self,
        path: str,
        params: Optional[dict[str, Any]] = None,
        *,
        accept: str = "application/vnd.github+json",
    ) -> list[Any]:
        page_params = dict(params or {})
        page_params.setdefault("per_page", 100)
        payload, headers = self._request(path, params=page_params, accept=accept)
        if not isinstance(payload, list):
            raise GitHubAPIError(f"Expected list response for {path}")
        items = list(payload)
        next_url = next_link(headers.get("Link"))
        while next_url:
            payload, headers = self._request(next_url, accept=accept)
            if not isinstance(payload, list):
                raise GitHubAPIError(f"Expected list response for {path}")
            items.extend(payload)
            next_url = next_link(headers.get("Link"))
        return items

    def is_org_member(self, org: str, login: str) -> bool:
        quoted_login = urllib.parse.quote(login, safe="")
        try:
            self.request(f"/orgs/{org}/members/{quoted_login}")
        except GitHubNotFound:
            return False
        return True

    def _request(
        self,
        path_or_url: str,
        params: Optional[dict[str, Any]] = None,
        *,
        accept: str,
        method: str = "GET",
        json_body: Optional[dict[str, Any]] = None,
    ) -> tuple[Any, Any]:
        if path_or_url.startswith("http://") or path_or_url.startswith("https://"):
            url = path_or_url
        else:
            query = f"?{urllib.parse.urlencode(params)}" if params else ""
            url = f"{GITHUB_API_BASE}{path_or_url}{query}"
        body = json.dumps(json_body).encode() if json_body is not None else None
        headers = {
            "Accept": accept,
            "Authorization": f"Bearer {self.token}",
            "User-Agent": "pwnshop-feedback",
            "X-GitHub-Api-Version": "2022-11-28",
        }
        if body is not None:
            headers["Content-Type"] = "application/json"
        request = urllib.request.Request(
            url,
            data=body,
            headers=headers,
            method=method,
        )
        for attempt in range(GITHUB_MAX_REQUEST_RETRIES + 1):
            last = attempt == GITHUB_MAX_REQUEST_RETRIES
            try:
                with urllib.request.urlopen(request, timeout=30) as response:
                    body = response.read().decode()
                    if response.status == 204 or not body:
                        return None, response.headers
                    return json.loads(body), response.headers
            except urllib.error.HTTPError as error:
                # HTTPError is a subclass of URLError, so it must be handled first.
                if error.code == 404:
                    raise GitHubNotFound(f"404 for {url}", status=404) from error
                detail = error.read().decode(errors="replace")
                retryable = error.code in GITHUB_RETRYABLE_STATUSES or (
                    error.code == 403 and "rate limit" in detail.lower()
                )
                if last or not retryable:
                    raise GitHubAPIError(
                        f"GitHub API request failed: {error.code} {url}: {detail}",
                        status=error.code,
                    ) from error
                delay = self._retry_delay(error.headers, attempt)
                logger.warning(
                    "transient GitHub %s on %s (attempt %d/%d); retrying in %.1fs",
                    error.code,
                    url,
                    attempt + 1,
                    GITHUB_MAX_REQUEST_RETRIES,
                    delay,
                )
            except (urllib.error.URLError, TimeoutError) as error:
                # Connection refused/reset, DNS, or socket timeout: always transient.
                if last:
                    reason = getattr(error, "reason", error)
                    raise GitHubAPIError(
                        f"GitHub API request failed: {url}: {reason}", status=None
                    ) from error
                delay = self._retry_delay(None, attempt)
                logger.warning(
                    "transient connection error on %s (attempt %d/%d); retrying in %.1fs: %s",
                    url,
                    attempt + 1,
                    GITHUB_MAX_REQUEST_RETRIES,
                    delay,
                    error,
                )
            time.sleep(delay)
        # Unreachable: the final attempt always returns or raises above.
        raise GitHubAPIError(f"GitHub API request failed: {url}", status=None)

    @staticmethod
    def _retry_delay(headers: Any, attempt: int) -> float:
        retry_after = headers.get("Retry-After") if headers else None
        if retry_after:
            try:
                return min(GITHUB_MAX_RETRY_DELAY_SECONDS, float(retry_after))
            except ValueError:
                pass
        return min(GITHUB_MAX_RETRY_DELAY_SECONDS, 2.0**attempt)


def next_link(link_header: Optional[str]) -> Optional[str]:
    if not link_header:
        return None
    for part in link_header.split(","):
        pieces = [piece.strip() for piece in part.split(";")]
        if len(pieces) < 2 or pieces[1] != 'rel="next"':
            continue
        if pieces[0].startswith("<") and pieces[0].endswith(">"):
            return pieces[0][1:-1]
    return None


def utc_now() -> datetime.datetime:
    return datetime.datetime.now(datetime.timezone.utc)


def parse_iso8601(value: str) -> datetime.datetime:
    return datetime.datetime.fromisoformat(value.replace("Z", "+00:00"))


def parse_channel_ids(values: Iterable[str], env_value: Optional[str]) -> list[str]:
    ids: list[str] = []
    for value in values:
        ids.extend(part for part in re.split(r"[\s,]+", value.strip()) if part)
    if env_value:
        ids.extend(part for part in re.split(r"[\s,]+", env_value.strip()) if part)
    return list(OrderedDict((item, None) for item in ids))


def channel_display_name(
    channel: dict[str, Any], channels_by_id: dict[str, dict[str, Any]]
) -> str:
    name = channel.get("name") or channel["id"]
    parent_id = channel.get("parent_id")
    if parent_id and parent_id in channels_by_id:
        return f"{channels_by_id[parent_id].get('name', parent_id)}/{name}"
    return name


def fetch_channel(api: DiscordAPI, channel_id: str) -> Optional[dict[str, Any]]:
    try:
        return api.request(f"/channels/{channel_id}")
    except DiscordPermissionError as error:
        logger.warning("skipping channel %s: %s", channel_id, error)
        return None


def discover_channels(
    api: DiscordAPI,
    guild_id: str,
    channel_ids: list[str],
    cutoff: datetime.datetime,
    include_threads: bool,
) -> tuple[list[dict[str, Any]], dict[str, dict[str, Any]]]:
    if channel_ids:
        channels = [
            channel
            for channel_id in channel_ids
            if (channel := fetch_channel(api, channel_id))
        ]
        channels_by_id = {channel["id"]: channel for channel in channels}
        return channels, channels_by_id

    guild_channels = api.request(f"/guilds/{guild_id}/channels")
    channels_by_id = {channel["id"]: channel for channel in guild_channels}
    message_channels = [
        channel
        for channel in guild_channels
        if channel.get("type") in TEXT_CHANNEL_TYPES
    ]

    if include_threads:
        # Active-thread enrichment is best-effort, mirroring the archived-thread scan
        # below; a transient guild-level error here must not abort the whole scrape.
        try:
            active_threads = api.request(f"/guilds/{guild_id}/threads/active").get(
                "threads", []
            )
        except (DiscordPermissionError, DiscordServerError) as error:
            logger.warning("skipping active threads for guild %s: %s", guild_id, error)
            active_threads = []
        public_active_threads = [
            thread
            for thread in active_threads
            if thread.get("type") in PUBLIC_THREAD_TYPES
        ]
        message_channels.extend(public_active_threads)
        channels_by_id.update(
            {thread["id"]: thread for thread in public_active_threads}
        )

        for parent in guild_channels:
            if parent.get("type") not in THREAD_PARENT_TYPES:
                continue
            for thread in fetch_public_archived_threads(api, parent, cutoff):
                if thread["id"] not in channels_by_id:
                    message_channels.append(thread)
                    channels_by_id[thread["id"]] = thread

    unique_channels = list(
        OrderedDict((channel["id"], channel) for channel in message_channels).values()
    )
    return unique_channels, channels_by_id


def fetch_public_archived_threads(
    api: DiscordAPI, parent: dict[str, Any], cutoff: datetime.datetime
) -> list[dict[str, Any]]:
    threads: list[dict[str, Any]] = []
    params: dict[str, Any] = {"limit": MAX_DISCORD_PAGE_SIZE}
    while True:
        try:
            page = api.request(
                f"/channels/{parent['id']}/threads/archived/public", params
            )
        except DiscordPermissionError:
            return threads
        except RuntimeError as error:
            logger.debug(
                "skipping archived threads for %s: %s",
                parent.get("name", parent["id"]),
                error,
            )
            return threads

        page_threads = page.get("threads", [])
        if not page_threads:
            return threads

        oldest_archive: Optional[datetime.datetime] = None
        for thread in page_threads:
            archive_timestamp = thread.get("thread_metadata", {}).get(
                "archive_timestamp"
            )
            if not archive_timestamp:
                continue
            archived_at = parse_iso8601(archive_timestamp)
            oldest_archive = (
                archived_at
                if oldest_archive is None
                else min(oldest_archive, archived_at)
            )
            if archived_at >= cutoff and thread.get("type") in PUBLIC_THREAD_TYPES:
                thread.setdefault("parent_id", parent["id"])
                threads.append(thread)

        if (
            not page.get("has_more")
            or oldest_archive is None
            or oldest_archive < cutoff
        ):
            return threads
        params["before"] = oldest_archive.isoformat()


def fetch_messages_since(
    api: DiscordAPI,
    channel: dict[str, Any],
    cutoff: datetime.datetime,
    max_messages: int,
) -> list[dict[str, Any]]:
    messages: list[dict[str, Any]] = []
    params: dict[str, Any] = {"limit": MAX_DISCORD_PAGE_SIZE}
    while len(messages) < max_messages:
        try:
            page = api.request(f"/channels/{channel['id']}/messages", params)
        except (DiscordPermissionError, DiscordServerError) as error:
            logger.warning(
                "skipping messages for %s: %s",
                channel.get("name", channel["id"]),
                error,
            )
            return messages

        if not page:
            return messages

        oldest_id: Optional[int] = None
        oldest_time: Optional[datetime.datetime] = None
        for message in page:
            message_time = parse_iso8601(message["timestamp"])
            message_id = int(message["id"])
            oldest_id = message_id if oldest_id is None else min(oldest_id, message_id)
            oldest_time = (
                message_time if oldest_time is None else min(oldest_time, message_time)
            )
            if message_time >= cutoff:
                messages.append(message)

        if oldest_id is None or oldest_time is None or oldest_time < cutoff:
            return messages[:max_messages]
        params["before"] = str(oldest_id)
    return messages[:max_messages]


def sanitize_content(content: str, channels_by_id: dict[str, dict[str, Any]]) -> str:
    def channel_replacement(match: re.Match[str]) -> str:
        channel_id = match.group(1)
        channel = channels_by_id.get(channel_id)
        if not channel:
            return "#channel"
        return f"#{channel.get('name', 'channel')}"

    content = re.sub(r"<#(\d+)>", channel_replacement, content)
    content = re.sub(r"<@!?\d+>", "@user", content)
    content = re.sub(r"<@&\d+>", "@role", content)
    content = re.sub(r"\b\d{17,20}\b", "<snowflake>", content)
    return content.strip()


def is_image_attachment(attachment: dict[str, Any]) -> bool:
    content_type = (attachment.get("content_type") or "").lower()
    if content_type.startswith("image/"):
        return True
    filename = (attachment.get("filename") or "").lower()
    return filename.endswith(IMAGE_ATTACHMENT_EXTENSIONS)


def attachment_local_name(attachment: dict[str, Any]) -> str:
    base = pathlib.Path(attachment.get("filename") or "image").name
    base = re.sub(r"[^A-Za-z0-9_.-]+", "-", base).strip("-.") or "image"
    return f"{attachment.get('id', 'attachment')}-{base}"


def download_image_attachment(
    url: str, dest: pathlib.Path, expected_size: Optional[int] = None
) -> Optional[pathlib.Path]:
    """Download a Discord image attachment to ``dest``; return the path, or None on failure.

    Best-effort: an oversize file or any network error is logged and skipped so one bad
    attachment can't abort the scrape. Discord CDN URLs are pre-signed, so we send no auth
    header (the bot token belongs to discord.com, not the cdn host).
    """
    if expected_size and expected_size > MAX_IMAGE_ATTACHMENT_BYTES:
        logger.warning(
            "skipping oversize image attachment %s (%d bytes)", dest.name, expected_size
        )
        return None
    request = urllib.request.Request(url, headers={"User-Agent": "pwnshop-feedback"})
    try:
        with urllib.request.urlopen(request, timeout=30) as response:
            data = response.read(MAX_IMAGE_ATTACHMENT_BYTES + 1)
    except (urllib.error.URLError, TimeoutError) as error:
        logger.warning("could not download image attachment %s: %s", dest.name, error)
        return None
    if len(data) > MAX_IMAGE_ATTACHMENT_BYTES:
        logger.warning(
            "skipping oversize image attachment %s (streamed past cap)", dest.name
        )
        return None
    dest.parent.mkdir(parents=True, exist_ok=True)
    dest.write_bytes(data)
    return dest


def sanitize_messages(
    messages_by_channel: list[tuple[dict[str, Any], list[dict[str, Any]]]],
    channels_by_id: dict[str, dict[str, Any]],
    guild_id: str,
    include_authors: bool,
    attachment_dir: Optional[pathlib.Path] = None,
) -> list[dict[str, Any]]:
    author_labels: dict[str, str] = {}
    sanitized: list[dict[str, Any]] = []
    for channel, messages in messages_by_channel:
        for message in messages:
            author = message.get("author", {})
            author_id = author.get("id", "unknown")
            if author_id not in author_labels:
                author_labels[author_id] = f"user-{len(author_labels) + 1:04d}"
            attachments = []
            image_refs = []
            for attachment in message.get("attachments", []):
                record = {
                    "filename": attachment.get("filename"),
                    "content_type": attachment.get("content_type"),
                    "size": attachment.get("size"),
                }
                url = attachment.get("url")
                if attachment_dir and url and is_image_attachment(attachment):
                    path = download_image_attachment(
                        url,
                        attachment_dir / attachment_local_name(attachment),
                        attachment.get("size"),
                    )
                    if path:
                        record["path"] = str(path)
                        image_refs.append(f"[image: {path}]")
                attachments.append(record)

            text = sanitize_content(message.get("content", ""), channels_by_id)
            # Reference each downloaded screenshot inline so the analysis agent reads it.
            parts = [part for part in [text, *image_refs] if part]
            if not parts and attachments:
                parts.append(
                    " ".join(
                        f"[attachment: {attachment['filename']}]"
                        for attachment in attachments
                    )
                )
            if not parts and message.get("embeds"):
                parts.append("[embed]")
            content = " ".join(parts).strip()

            item = {
                "id": message["id"],
                "link": f"https://discord.com/channels/{guild_id}/{channel['id']}/{message['id']}",
                "timestamp": message["timestamp"],
                "channel_id": channel["id"],
                "channel": channel_display_name(channel, channels_by_id),
                "author": author_labels[author_id],
                "content": content,
                "attachments": attachments,
                "reply_to": (message.get("referenced_message") or {}).get("id"),
            }
            if include_authors:
                item["author_name"] = author.get("global_name") or author.get(
                    "username"
                )
            sanitized.append(item)

    return sorted(sanitized, key=lambda item: item["timestamp"])


def write_transcript(
    artifact_dir: pathlib.Path,
    messages: list[dict[str, Any]],
    since: datetime.datetime,
    until: datetime.datetime,
) -> tuple[pathlib.Path, pathlib.Path]:
    jsonl_path = artifact_dir / "messages.jsonl"
    md_path = artifact_dir / "transcript.md"
    with jsonl_path.open("w") as output:
        for message in messages:
            output.write(json.dumps(message, sort_keys=True) + "\n")

    lines = [
        "# Discord Feedback Transcript",
        "",
        f"Window: {since.isoformat()} through {until.isoformat()}",
        f"Messages: {len(messages)}",
        "",
        "Author labels are per-run pseudonyms. User mentions and raw snowflake IDs are redacted.",
    ]
    if any(
        attachment.get("path")
        for message in messages
        for attachment in message["attachments"]
    ):
        lines.append(
            "Image attachments are saved locally and referenced inline as `[image: PATH]`; "
            "open those files to view the screenshots."
        )
    lines.append("")
    last_channel = None
    for message in messages:
        if message["channel"] != last_channel:
            lines.extend(["", f"## #{message['channel']}", ""])
            last_channel = message["channel"]
        timestamp = parse_iso8601(message["timestamp"]).strftime(
            "%Y-%m-%d %H:%M:%S UTC"
        )
        content = message["content"].replace("\n", "\n  ")
        lines.append(
            f"- {timestamp} [{message['author']}]({message['link']}): {content}"
        )
    md_path.write_text("\n".join(lines).rstrip() + "\n")
    return jsonl_path, md_path


def git_root() -> pathlib.Path:
    return pathlib.Path(
        subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"], text=True
        ).strip()
    )


def git_output(args: list[str], cwd: pathlib.Path) -> str:
    return subprocess.check_output(["git", *args], cwd=cwd, text=True).rstrip("\n")


def github_repo_slug(repo: pathlib.Path) -> tuple[str, str]:
    remote = git_output(["remote", "get-url", "origin"], repo)
    patterns = [
        r"github\.com[:/](?P<owner>[^/]+)/(?P<name>[^/.]+)(?:\.git)?$",
        r"^git@github\.com:(?P<owner>[^/]+)/(?P<name>[^/.]+)(?:\.git)?$",
    ]
    for pattern in patterns:
        match = re.search(pattern, remote)
        if match:
            return match.group("owner"), match.group("name")
    raise click.ClickException(f"Could not parse GitHub origin remote: {remote}")


def parse_pr_number(pr_url: str) -> int:
    if pr_url.isdigit():
        return int(pr_url)
    match = re.search(r"/pull/(\d+)(?:\D|$)", pr_url)
    if not match:
        raise click.ClickException(f"Could not parse pull request number from {pr_url}")
    return int(match.group(1))


def ensure_clean_worktree(repo: pathlib.Path) -> None:
    status = git_output(["status", "--porcelain"], repo)
    if status:
        raise click.ClickException(
            "Working tree is dirty. Commit/stash existing changes or rerun with --allow-dirty."
        )


def prepare_branch(
    repo: pathlib.Path, branch: Optional[str], create_pr: bool, run_id: str
) -> str:
    current = git_output(["branch", "--show-current"], repo)
    target = branch
    if create_pr and not target and current in {"main", "master"}:
        target = f"feedback/{run_id}"
    if target and current != target:
        existing = subprocess.run(
            ["git", "rev-parse", "--verify", target],
            cwd=repo,
            capture_output=True,
            text=True,
        )
        if existing.returncode == 0:
            subprocess.run(["git", "switch", target], cwd=repo, check=True)
        else:
            subprocess.run(["git", "switch", "-c", target], cwd=repo, check=True)
        return target
    return current


def format_duration(seconds: float) -> str:
    seconds = int(seconds)
    minutes, seconds = divmod(seconds, 60)
    hours, minutes = divmod(minutes, 60)
    if hours:
        return f"{hours}h{minutes:02d}m{seconds:02d}s"
    if minutes:
        return f"{minutes}m{seconds:02d}s"
    return f"{seconds}s"


def ellipsize(value: str, limit: int = STATUS_TEXT_LIMIT) -> str:
    value = " ".join(value.split())
    if len(value) <= limit:
        return value
    return value[: limit - 3].rstrip() + "..."


def with_automation_notice(body: str) -> str:
    body = body.lstrip()
    if body.startswith(AUTOMATED_MESSAGE_NOTICE):
        return body.rstrip() + "\n"
    return f"{AUTOMATED_MESSAGE_NOTICE}\n\n{body}".rstrip() + "\n"


def stream_log_path(output_path: pathlib.Path, suffix: str) -> pathlib.Path:
    return output_path.with_name(f"{output_path.name}.{suffix}")


def insert_before_stdin_prompt(args: list[str], additions: list[str]) -> list[str]:
    if args and args[-1] == "-":
        return [*args[:-1], *additions, args[-1]]
    return [*args, *additions]


def terminate_process_tree(
    process: "subprocess.Popen[Any]", *, grace_seconds: float = 5.0
) -> None:
    """Best-effort teardown of a child and everything it spawned.

    stream_command starts children with start_new_session=True, so the process and its
    descendants share a process group. Signalling the group (rather than the lone leader)
    reaps the grandchildren -- here `nix -> pwnshop -> asciinema -> docker exec` -- that a
    bare process.kill() would orphan. SIGINT first so pwnshop's own cleanup (tearing down
    the challenge container) can run; escalate to SIGKILL only if it ignores us.
    """
    if process.poll() is not None:
        return
    try:
        pgid = os.getpgid(process.pid)
    except ProcessLookupError:
        return
    for sig in (signal.SIGINT, signal.SIGKILL):
        try:
            os.killpg(pgid, sig)
        except ProcessLookupError:
            return
        try:
            process.wait(timeout=grace_seconds)
            return
        except subprocess.TimeoutExpired:
            continue


def stream_command(
    command: list[str],
    *,
    cwd: pathlib.Path,
    log_path: pathlib.Path,
    input_text: Optional[str] = None,
    timeout: Optional[int] = None,
    line_handler: Optional[Any] = None,
    echo_output: bool = False,
    heartbeat_label: Optional[str] = None,
) -> int:
    started = time.monotonic()
    last_heartbeat = started
    timed_out = False
    input_file = None
    process = None

    if input_text is not None:
        input_file = tempfile.TemporaryFile(mode="w+", encoding="utf-8")
        input_file.write(input_text)
        input_file.seek(0)

    click.echo(f"Running: {shlex.join(command)}")
    click.echo(f"Log: {log_path}")

    try:
        with log_path.open("w") as log:
            process = subprocess.Popen(
                command,
                cwd=cwd,
                stdin=input_file or subprocess.DEVNULL,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1,
                start_new_session=True,
            )
            output_queue = queue.Queue()

            def read_output() -> None:
                assert process.stdout is not None
                try:
                    for line in process.stdout:
                        output_queue.put(line)
                finally:
                    output_queue.put(None)

            reader = threading.Thread(target=read_output, daemon=True)
            reader.start()

            while True:
                if timeout and time.monotonic() - started > timeout:
                    timed_out = True
                    terminate_process_tree(process)
                    click.echo(
                        f"{heartbeat_label or 'Command'} timed out after {timeout}s"
                    )
                    break

                try:
                    line = output_queue.get(timeout=0.2)
                except queue.Empty:
                    if (
                        heartbeat_label
                        and time.monotonic() - last_heartbeat
                        >= STATUS_HEARTBEAT_SECONDS
                    ):
                        click.echo(
                            f"{heartbeat_label} still running "
                            f"({format_duration(time.monotonic() - started)} elapsed)"
                        )
                        last_heartbeat = time.monotonic()
                    if process.poll() is not None and not reader.is_alive():
                        break
                    continue

                if line is None:
                    break

                log.write(line)
                log.flush()
                if echo_output:
                    click.echo(line, nl=False)
                if line_handler:
                    line_handler(line.rstrip("\n"))

            return_code = process.wait()
            reader.join(timeout=1)
    finally:
        # Covers Ctrl-C and any unexpected error: tear down the child tree (and the
        # challenge container it spawned) instead of orphaning it. No-op on the normal and
        # timeout paths, where the process has already exited.
        if process is not None:
            terminate_process_tree(process)
        if input_file:
            input_file.close()

    elapsed = format_duration(time.monotonic() - started)
    if timed_out:
        raise subprocess.TimeoutExpired(command, timeout)
    click.echo(f"Finished with exit code {return_code} in {elapsed}")
    return return_code


def agent_event_type(event: dict[str, Any]) -> str:
    value = event.get("type") or event.get("event") or event.get("name")
    return str(value) if value is not None else "event"


def summarize_claude_event(event: dict[str, Any]) -> Optional[str]:
    event_type = agent_event_type(event)
    if event_type == "system":
        subtype = event.get("subtype")
        suffix = f" ({subtype})" if subtype else ""
        return f"session initialized{suffix}"
    if event_type == "assistant":
        message = event.get("message", {})
        content = message.get("content", [])
        tool_names = [
            block.get("name")
            for block in content
            if isinstance(block, dict) and block.get("type") == "tool_use"
        ]
        tool_names = [name for name in tool_names if name]
        if tool_names:
            return f"using tool(s): {', '.join(tool_names)}"
        if any(
            isinstance(block, dict) and block.get("type") == "text"
            for block in content
        ):
            return "wrote an assistant message"
        return "assistant event"
    if event_type == "result":
        duration = event.get("duration_ms")
        cost = event.get("total_cost_usd")
        details = []
        if duration is not None:
            details.append(format_duration(float(duration) / 1000))
        if cost is not None:
            details.append(f"${float(cost):.4f}")
        suffix = f" ({', '.join(details)})" if details else ""
        if event.get("is_error"):
            return f"failed{suffix}"
        return f"completed{suffix}"
    if "error" in event_type.lower() or event.get("error"):
        return f"error: {ellipsize(str(event.get('error') or event))}"
    return None


def summarize_codex_event(event: dict[str, Any]) -> Optional[str]:
    event_type = agent_event_type(event)
    if event_type in {"thread.started", "turn.started", "turn.completed"}:
        return event_type.replace(".", " ")
    if event_type.endswith(".output") or event_type.endswith(".delta"):
        return None

    item = event.get("item")
    if isinstance(item, dict):
        item_type = item.get("type")

        if item_type == "agent_message":
            text = item.get("text") or item.get("message")
            if text:
                return f"message: {ellipsize(str(text), AGENT_MESSAGE_TEXT_LIMIT)}"
            return "agent message"

        if item_type == "command_execution":
            command = item.get("command")
            if event_type.endswith(".started"):
                return f"running command: {ellipsize(str(command), 260)}"
            exit_code = item.get("exit_code")
            output = str(item.get("aggregated_output") or "").strip()
            summary = f"command exited {exit_code}"
            if output:
                summary += f": {ellipsize(output, COMMAND_OUTPUT_TEXT_LIMIT)}"
            return summary

        if item_type == "file_change":
            changes = item.get("changes") or []
            formatted_changes = []
            for change in changes:
                if not isinstance(change, dict):
                    continue
                kind = change.get("kind", "change")
                path = change.get("path", "")
                formatted_changes.append(f"{kind} {path}")
            status = item.get("status") or event_type.rsplit(".", 1)[-1]
            if formatted_changes:
                return (
                    f"file changes {status}: "
                    f"{ellipsize(', '.join(formatted_changes), 360)}"
                )
            return f"file changes {status}"

        if item_type in {"mcp_tool_call", "web_search"}:
            name = (
                item.get("name")
                or item.get("tool_name")
                or item.get("query")
                or item_type
            )
            action = "started" if event_type.endswith(".started") else "completed"
            return f"{action} {item_type}: {ellipsize(str(name), 260)}"

        if item_type:
            action = event_type.rsplit(".", 1)[-1]
            return f"{action}: {item_type}"

    if event_type.endswith(".begin") or event_type.endswith(".started"):
        command = event.get("command") or event.get("cmd")
        if command:
            return f"{event_type}: {ellipsize(str(command))}"
        return event_type.replace(".", " ")
    if event_type.endswith(".end") or event_type.endswith(".completed"):
        exit_code = event.get("exit_code")
        if exit_code is not None:
            return f"{event_type}: exit code {exit_code}"
        return event_type.replace(".", " ")
    if "error" in event_type.lower() or event.get("error"):
        return f"error: {ellipsize(str(event.get('error') or event))}"
    if event.get("message"):
        return f"{event_type}: {ellipsize(str(event['message']))}"
    return None


def codex_base_command() -> Optional[list[str]]:
    if shutil.which("npm"):
        return ["npm", "exec", "--yes", "@openai/codex@latest", "--", "codex"]
    if shutil.which("codex"):
        return ["codex"]
    return None


def resolve_agent(agent: str, apply: bool) -> tuple[str, list[str]]:
    if agent == "auto":
        if codex_base_command():
            agent = "codex"
        elif shutil.which("claude"):
            agent = "claude"
        else:
            raise click.ClickException(
                "No supported agent found (`npm`, `codex`, or `claude`)."
            )

    if agent == "claude":
        if not shutil.which("claude"):
            raise click.ClickException("`claude` was requested but is not on PATH.")
        args = ["claude", "-p", "--no-session-persistence"]
        if apply:
            args.extend(["--permission-mode", "bypassPermissions"])
        return agent, args

    if agent == "codex":
        codex_base = codex_base_command()
        if not codex_base:
            raise click.ClickException(
                "`codex` was requested but neither `npm` nor `codex` is on PATH."
            )
        args = [
            *codex_base,
            "exec",
            "--skip-git-repo-check",
            "--cd",
            str(git_root()),
        ]
        if apply:
            args.append("--dangerously-bypass-approvals-and-sandbox")
        else:
            args.extend(["--sandbox", "danger-full-access"])
        args.append("-")
        return agent, args

    raise click.ClickException(f"Unsupported agent: {agent}")


def run_agent(
    agent: str,
    prompt: str,
    *,
    repo: pathlib.Path,
    artifact_dir: pathlib.Path,
    output_name: str,
    apply: bool = False,
) -> pathlib.Path:
    resolved, args = resolve_agent(agent, apply)
    output_path = artifact_dir / output_name
    final_result: list[str] = []
    assistant_messages: list[str] = []

    if resolved == "codex":
        stream_path = stream_log_path(output_path, "stream.jsonl")
        args = insert_before_stdin_prompt(
            args,
            [
                "--json",
                "--color",
                "never",
                "--output-last-message",
                str(output_path),
            ],
        )
    elif resolved == "claude":
        stream_path = stream_log_path(output_path, "stream.jsonl")
        args = [*args, "--output-format", "stream-json"]
    else:
        stream_path = stream_log_path(output_path, "stream.log")

    def handle_agent_line(line: str) -> None:
        if not line:
            return
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            click.echo(f"{resolved}: {ellipsize(line)}")
            assistant_messages.append(line)
            return

        if resolved == "claude":
            if event.get("type") == "result" and isinstance(event.get("result"), str):
                final_result.append(event["result"])
            elif event.get("type") == "assistant":
                message = event.get("message", {})
                content = message.get("content", [])
                for block in content:
                    if isinstance(block, dict) and block.get("type") == "text":
                        assistant_messages.append(block.get("text", ""))
            summary = summarize_claude_event(event)
        elif resolved == "codex":
            summary = summarize_codex_event(event)
        else:
            summary = None

        if summary:
            click.echo(f"{resolved}: {summary}")

    click.echo(f"Starting {resolved} agent for {output_name}")
    rc = stream_command(
        args,
        input_text=prompt,
        cwd=repo,
        log_path=stream_path,
        line_handler=handle_agent_line,
        heartbeat_label=f"{resolved} agent for {output_name}",
    )

    if resolved == "claude":
        if final_result:
            output_path.write_text(final_result[-1])
        elif assistant_messages:
            output_path.write_text("\n".join(assistant_messages).rstrip() + "\n")
        elif rc == 0:
            output_path.write_text("")

    if rc != 0:
        raise click.ClickException(
            f"{resolved} failed for {output_name}; see {stream_path}"
        )
    if not output_path.exists():
        raise click.ClickException(
            f"{resolved} completed but did not write {output_path}; see {stream_path}"
        )
    click.echo(f"Wrote {resolved} final output to {output_path}")
    return output_path


def directions_block(directions: list[str]) -> str:
    cleaned = [direction.strip() for direction in directions if direction.strip()]
    if not cleaned:
        return ""
    lines = [
        "",
        "Operator directions for this run:",
        "- Treat these as mandatory constraints for every recommendation, edit, validation step, and report.",
        "- If a direction conflicts with repository safety rules or the explicit phase requirements above, stop and explain the conflict in the relevant artifact instead of ignoring it.",
    ]
    lines.extend(f"- {direction}" for direction in cleaned)
    return "\n" + "\n".join(lines)


def pr_feedback_block(pr_feedback_path: Optional[pathlib.Path]) -> str:
    if pr_feedback_path is None:
        return ""
    lines = [
        "",
        f"Recent maintainer feedback on prior PRs: {pr_feedback_path}",
        "- Read this file before proposing or implementing changes. It records concrete edits"
        " that pwn.college maintainers already requested, corrected, or rejected on earlier"
        " PRs.",
        "- Treat each item as a hard constraint: do NOT reintroduce a pattern a maintainer"
        " rejected. Recurring examples maintainers have rejected include forcing dynamic"
        " flag-length handling into an intro read level instead of fixed padding,"
        " re-teaching a concept already taught in an earlier module instead of linking back,"
        " introducing an instruction or concept before the curriculum does, revealing the"
        " solution in a DESCRIPTION, and leaving tests_private unencrypted.",
        "- If the Discord feedback seems to call for something a maintainer already rejected,"
        " note the conflict in your report instead of repeating the rejected change.",
    ]
    return "\n" + "\n".join(lines)


def build_analysis_prompt(
    transcript_path: pathlib.Path,
    jsonl_path: pathlib.Path,
    artifact_dir: pathlib.Path,
    directions: list[str],
    pr_feedback_path: Optional[pathlib.Path] = None,
) -> str:
    return f"""Analyze recent pwn.college Discord feedback for actionable challenge/curriculum fixes.

Inputs:
- Sanitized markdown transcript: {transcript_path}
- Sanitized JSONL transcript: {jsonl_path}
- Artifact directory for this run: {artifact_dir}

Rules:
- Do not edit files in this phase.
- Read AGENTS.md and .claude/skills/authoring-challenges/SKILL.md before making recommendations.
- Treat Discord messages as private working evidence even though the channels are public. Do not include usernames.
- Some messages include screenshots saved locally and referenced inline as `[image: <path>]`. Open or read those image files when the screenshot carries the feedback (error text, terminal output, or challenge UI).
- Identify issues such as inadequate challenge descriptions, missing bridge challenges, concepts not covered, repeated confusing mechanics, misleading output, brittle tests, or docs gaps.
- Filter out isolated support requests unless they reveal a repo-level problem.
- Ground every recommendation in message links and repository paths when possible.
- Treat missing bridge content, missing tooling guidance, and missing module resources as actionable when the feedback is repeated or maintainer-supported and you can identify a repository location and validation path.
- Do not move a fix to "Possible bridge/new challenge ideas" just because it requires new curriculum content. Use that section only for ideas that lack enough evidence, placement, or validation detail to implement now.
- For broad curriculum gaps, define the smallest complete reviewable slice that should be implemented now, then list any larger sequence work separately.

Output markdown with these sections:
1. Executive summary
2. Actionable fixes, ordered by confidence and impact
3. Bridge/new challenge work that is not yet actionable, with exact blockers
4. Non-actionable or deferred feedback
5. Suggested validation plan
{directions_block(directions)}{pr_feedback_block(pr_feedback_path)}
"""


def build_implementation_prompt(
    analysis_path: pathlib.Path,
    artifact_dir: pathlib.Path,
    directions: list[str],
    pr_feedback_path: Optional[pathlib.Path] = None,
) -> str:
    return f"""Implement high-confidence pwn.college challenge/curriculum improvements from this feedback analysis:

{analysis_path}

Requirements:
- Read AGENTS.md and .claude/skills/authoring-challenges/SKILL.md before editing challenge content.
- If you revise or add a challenge, follow the local authoring-challenges guidance. Read 2-3 sibling levels first, extend common templates, keep one new concept per level, and avoid unverified learner-facing claims.
- Make all changes directly supported by the analysis, including new bridge challenges, module resources, and tooling guidance when the analysis gives enough evidence, placement, and a validation path.
- Size alone is not a reason to defer. If an item is broad, implement the smallest complete reviewable slice that addresses the feedback now, then document only the remaining unsolved scope.
- "Verify available runtime tools" is an action, not a deferral reason: inspect the relevant Dockerfile/common image or run the tool check, then update guidance or package dependencies based on what you find.
- Write to {artifact_dir}/deferred.md only for items with a concrete blocker such as missing evidence, ambiguous placement requiring maintainer choice, external repository ownership, unavailable encrypted tests, or an implementation that cannot be validated in this repo.
- Every deferred item must name its blocker and the next action that would unblock it. Do not write generic phrases like "larger design item", "speculative", or "needs design" without the concrete blocker.
- Do not commit, push, open a PR, or add the Discord transcript to the repo.
- Do not claim tests pass unless you run them. The outer tool will run pwnshop tests afterward, so focus on making the repo changes and noting any special validation needed.
- Keep changes reviewable and scoped.

When done, write a concise implementation note to {artifact_dir}/implementation-notes.md and include:
- changed challenge/module paths
- what learner confusion each change addresses
- any tests or playtests you recommend
{directions_block(directions)}{pr_feedback_block(pr_feedback_path)}
"""



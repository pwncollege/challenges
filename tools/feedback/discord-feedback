def post_issue_comment(
    api: GitHubAPI,
    owner: str,
    repo_name: str,
    issue_number: int,
    body: str,
) -> None:
    api.post(
        f"/repos/{owner}/{repo_name}/issues/{issue_number}/comments",
        {"body": with_automation_notice(body)},
    )


def clear_pending_review(
    api: GitHubAPI, owner: str, repo_name: str, pull_number: int
) -> bool:
    """Delete the token user's leftover *empty* PENDING (draft) review on the PR.

    GitHub rejects a review-comment reply with 422 "user_id can only have one pending
    review per pull request" when the authenticated user has a stale draft review (left
    behind by an interrupted run). Deleting that draft unblocks replies.

    Guards against destroying real work: only the authenticated user's own drafts
    (state == "PENDING") are considered, and only ones that are *empty* -- no body and no
    draft comments -- are deleted. A maintainer running this bot with their own PAT may
    have a genuine review in progress on the same PR; a non-empty draft is left untouched
    (the reply just stays unposted) rather than discarding their unsubmitted work.
    """
    me = api.authenticated_login()
    if not me:
        return False
    try:
        reviews = api.request_all(
            f"/repos/{owner}/{repo_name}/pulls/{pull_number}/reviews"
        )
    except GitHubAPIError as error:
        logger.warning("could not list reviews on PR #%s: %s", pull_number, error)
        return False
    cleared = False
    for review in reviews:
        review_id = review.get("id")
        if review.get("state") != "PENDING":
            continue
        if (review.get("user") or {}).get("login") != me:
            continue
        if (review.get("body") or "").strip():
            logger.warning(
                "leaving non-empty pending review %s on PR #%s in place",
                review_id,
                pull_number,
            )
            continue
        try:
            draft_comments = api.request_all(
                f"/repos/{owner}/{repo_name}/pulls/{pull_number}/reviews/{review_id}/comments"
            )
        except GitHubAPIError as error:
            logger.warning(
                "could not inspect pending review %s on PR #%s (%s); leaving it in place",
                review_id,
                pull_number,
                error,
            )
            continue
        if draft_comments:
            logger.warning(
                "leaving pending review %s with %d draft comment(s) on PR #%s in place",
                review_id,
                len(draft_comments),
                pull_number,
            )
            continue
        try:
            api.delete(
                f"/repos/{owner}/{repo_name}/pulls/{pull_number}/reviews/{review_id}"
            )
            cleared = True
            click.echo(f"Cleared an empty stale pending review on PR #{pull_number}")
        except GitHubAPIError as error:
            logger.warning(
                "could not delete pending review %s on PR #%s: %s",
                review_id,
                pull_number,
                error,
            )
    return cleared


def post_review_comment_reply(
    api: GitHubAPI,
    owner: str,
    repo_name: str,
    pull_number: int,
    comment_id: int,
    body: str,
) -> None:
    path = f"/repos/{owner}/{repo_name}/pulls/{pull_number}/comments/{comment_id}/replies"
    payload = {"body": with_automation_notice(body)}
    try:
        api.post(path, payload)
    except GitHubAPIError as error:
        # A stale draft review blocks replies with 422; clear it and retry once.
        if error.status == 422 and clear_pending_review(
            api, owner, repo_name, pull_number
        ):
            api.post(path, payload)
        else:
            raise


def event_time(item: dict[str, Any]) -> str:
    return (
        item.get("updated_at")
        or item.get("submitted_at")
        or item.get("created_at")
        or ""
    )


def pr_event_key(kind: str, item: dict[str, Any]) -> str:
    return f"{kind}:{item.get('id')}:{event_time(item)}"


def is_codex_author(login: str) -> bool:
    return login.lower() in TRUSTED_PR_BOT_LOGINS


def accepted_pr_actor_reason(
    api: GitHubAPI,
    membership_cache: dict[str, bool],
    login: str,
) -> Optional[str]:
    if not login:
        return None
    if is_codex_author(login):
        return "codex-review"
    if login not in membership_cache:
        try:
            membership_cache[login] = api.is_org_member(
                PWN_COLLEGE_GITHUB_ORG, login
            )
        except GitHubAPIError as error:
            logger.warning(
                "could not verify GitHub org membership for %s: %s", login, error
            )
            membership_cache[login] = False
    if membership_cache[login]:
        return f"{PWN_COLLEGE_GITHUB_ORG}-org-member"
    return None


def compact_text(value: Optional[str], limit: int = 6000) -> str:
    if not value:
        return ""
    if len(value) <= limit:
        return value
    return value[: limit - 80].rstrip() + "\n...[truncated]..."


def compact_pr_event(
    kind: str,
    item: dict[str, Any],
    reason: str,
) -> Optional[dict[str, Any]]:
    body = (item.get("body") or "").strip()
    state = item.get("state")
    if kind == "review" and not body and state not in {"CHANGES_REQUESTED"}:
        return None
    if kind != "review" and not body:
        return None

    user = item.get("user") or {}
    event: dict[str, Any] = {
        "key": pr_event_key(kind, item),
        "id": item.get("id"),
        "kind": kind,
        "accepted_reason": reason,
        "author": user.get("login"),
        "url": item.get("html_url"),
        "created_at": item.get("created_at") or item.get("submitted_at"),
        "updated_at": item.get("updated_at"),
        "body": compact_text(body),
    }
    if state:
        event["state"] = state
    if kind == "review_comment":
        event.update(
            {
                "path": item.get("path"),
                "line": item.get("line") or item.get("original_line"),
                "side": item.get("side"),
                "diff_hunk": compact_text(item.get("diff_hunk"), limit=3000),
                "review_id": item.get("pull_request_review_id"),
            }
        )
    return event


def is_generated_feedback_item(item: dict[str, Any]) -> bool:
    return (item.get("body") or "").lstrip().startswith(AUTOMATED_MESSAGE_NOTICE)


def collect_pr_feedback_events(
    api: GitHubAPI,
    owner: str,
    repo_name: str,
    pr_number: int,
    membership_cache: dict[str, bool],
) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:
    sources = [
        (
            "issue_comment",
            api.request_all(f"/repos/{owner}/{repo_name}/issues/{pr_number}/comments"),
        ),
        (
            "review_comment",
            api.request_all(f"/repos/{owner}/{repo_name}/pulls/{pr_number}/comments"),
        ),
        (
            "review",
            api.request_all(f"/repos/{owner}/{repo_name}/pulls/{pr_number}/reviews"),
        ),
    ]
    accepted: list[dict[str, Any]] = []
    ignored: list[dict[str, Any]] = []
    for kind, items in sources:
        for item in items:
            if is_generated_feedback_item(item):
                continue
            user = item.get("user") or {}
            login = user.get("login") or ""
            key = pr_event_key(kind, item)
            reason = accepted_pr_actor_reason(api, membership_cache, login)
            if reason:
                event = compact_pr_event(kind, item, reason)
                if event:
                    accepted.append(event)
                continue
            ignored.append(
                {
                    "key": key,
                    "kind": kind,
                    "author": login,
                    "url": item.get("html_url"),
                }
            )
    accepted.sort(key=lambda item: item.get("created_at") or "")
    return accepted, ignored


def is_maintainer_login(
    api: GitHubAPI,
    membership_cache: dict[str, bool],
    login: str,
) -> bool:
    """True only for pwn.college org members; bots and outside contributors are excluded."""
    if not login:
        return False
    if login not in membership_cache:
        try:
            membership_cache[login] = api.is_org_member(PWN_COLLEGE_GITHUB_ORG, login)
        except GitHubAPIError as error:
            logger.warning(
                "could not verify GitHub org membership for %s: %s", login, error
            )
            membership_cache[login] = False
    return membership_cache[login]


def fetch_recent_pull_requests(
    api: GitHubAPI,
    owner: str,
    repo_name: str,
    since_iso: str,
) -> list[dict[str, Any]]:
    """Pull requests in owner/repo_name updated at or after since_iso, newest first."""
    pulls = api.request_all(
        f"/repos/{owner}/{repo_name}/pulls",
        params={
            "state": "all",
            "sort": "updated",
            "direction": "desc",
            "per_page": 100,
        },
    )
    recent = [pull for pull in pulls if (pull.get("updated_at") or "") >= since_iso]
    recent.sort(key=lambda pull: pull.get("updated_at") or "", reverse=True)
    return recent


def is_bot_pull(pull: dict[str, Any]) -> bool:
    """True when this PR was opened by the feedback bot itself.

    The bot pushes ``feedback/<run-id>`` branches and prefixes every PR body with the
    automation notice, so either signal marks one of our own PRs.
    """
    head_ref = (pull.get("head") or {}).get("ref") or ""
    if head_ref.startswith("feedback/"):
        return True
    return (pull.get("body") or "").lstrip().startswith(AUTOMATED_MESSAGE_NOTICE)


def find_last_merged_bot_pr(
    api: GitHubAPI,
    owner: str,
    repo_name: str,
    *,
    page_cap: int = MERGED_PR_SCAN_PAGE_CAP,
) -> Optional[dict[str, Any]]:
    """The most recently merged PR opened by the feedback bot, or None.

    Scans closed PRs newest-updated first. A PR's ``updated_at`` is always >= its
    ``merged_at``, so once a page's oldest ``updated_at`` falls at/under the best
    ``merged_at`` seen so far no later page can beat it and we stop -- ``page_cap`` is only
    a backstop against an unbounded crawl.
    """
    path = f"/repos/{owner}/{repo_name}/pulls"
    best: Optional[dict[str, Any]] = None
    for page in range(1, page_cap + 1):
        pulls = api.request(
            path,
            params={
                "state": "closed",
                "sort": "updated",
                "direction": "desc",
                "per_page": 100,
                "page": page,
            },
        )
        if not isinstance(pulls, list) or not pulls:
            break
        for pull in pulls:
            merged_at = pull.get("merged_at")
            if merged_at and is_bot_pull(pull):
                if best is None or merged_at > best["merged_at"]:
                    best = pull
        page_oldest_updated = pulls[-1].get("updated_at") or ""
        if best is not None and page_oldest_updated <= best["merged_at"]:
            break
        if len(pulls) < 100:
            break
    return best


def resolve_scrape_since(
    repo: pathlib.Path,
    until: datetime.datetime,
    hours: Optional[int],
    fallback_hours: int,
) -> datetime.datetime:
    """Pick where the Discord scrape should start.

    With an explicit ``--hours`` the caller forces a fixed lookback window. Otherwise we
    resume from the last merged feedback PR -- specifically from when that PR was opened,
    minus ``IMPLEMENTATION_BUFFER_HOURS`` so messages that arrived while that batch was still
    being implemented are re-covered rather than skipped. Falls back to ``fallback_hours``
    when no such PR (or no GitHub access) is available.
    """
    if hours is not None:
        return until - datetime.timedelta(hours=hours)

    fallback = until - datetime.timedelta(hours=fallback_hours)
    try:
        api = GitHubAPI.from_environment(repo)
        owner, repo_name = github_repo_slug(repo)
        pull = find_last_merged_bot_pr(api, owner, repo_name)
    except (click.ClickException, GitHubAPIError, OSError) as error:
        click.echo(
            f"Could not locate the last merged feedback PR ({error}); "
            f"scraping the last {fallback_hours}h instead."
        )
        return fallback
    if not pull:
        click.echo(
            f"No merged feedback PR found; scraping the last {fallback_hours}h instead."
        )
        return fallback
    opened_at = parse_iso8601(pull["created_at"])
    since = opened_at - datetime.timedelta(hours=IMPLEMENTATION_BUFFER_HOURS)
    click.echo(
        f"Resuming from merged feedback PR #{pull.get('number')} "
        f"(opened {opened_at.isoformat()}, scraping from "
        f"{IMPLEMENTATION_BUFFER_HOURS}h earlier to catch in-flight messages)."
    )
    return since


def collect_maintainer_pr_feedback(
    api: GitHubAPI,
    owner: str,
    repo_name: str,
    pulls: list[dict[str, Any]],
    membership_cache: dict[str, bool],
) -> list[dict[str, Any]]:
    """Org-member (maintainer) comments/reviews on the given PRs, grouped per PR.

    Drops our own automated-notice replies and any non-org-member author (bots, outside
    contributors), so the agents only ever see real maintainer guidance.
    """
    feedback: list[dict[str, Any]] = []
    for pull in pulls:
        number = pull.get("number")
        if number is None:
            continue
        sources = [
            (
                "issue_comment",
                api.request_all(f"/repos/{owner}/{repo_name}/issues/{number}/comments"),
            ),
            (
                "review_comment",
                api.request_all(f"/repos/{owner}/{repo_name}/pulls/{number}/comments"),
            ),
            (
                "review",
                api.request_all(f"/repos/{owner}/{repo_name}/pulls/{number}/reviews"),
            ),
        ]
        events: list[dict[str, Any]] = []
        for kind, items in sources:
            for item in items:
                if is_generated_feedback_item(item):
                    continue
                login = (item.get("user") or {}).get("login") or ""
                if not is_maintainer_login(api, membership_cache, login):
                    continue
                event = compact_pr_event(kind, item, "pwncollege-org-member")
                if event:
                    events.append(event)
        if not events:
            continue
        events.sort(key=lambda event: event.get("created_at") or "")
        feedback.append(
            {
                "number": number,
                "title": pull.get("title"),
                "state": pull.get("state"),
                "merged": pull.get("merged_at") is not None,
                "url": pull.get("html_url"),
                "updated_at": pull.get("updated_at"),
                "events": events,
            }
        )
    return feedback


def write_pr_feedback(
    artifact_dir: pathlib.Path,
    feedback: list[dict[str, Any]],
    since: datetime.datetime,
    until: datetime.datetime,
) -> Optional[pathlib.Path]:
    """Write maintainer PR feedback artifacts. Returns the markdown path, or None if empty."""
    total_events = sum(len(pull["events"]) for pull in feedback)
    if total_events == 0:
        return None

    jsonl_path = artifact_dir / "recent-pr-feedback.jsonl"
    with jsonl_path.open("w") as handle:
        for pull in feedback:
            for event in pull["events"]:
                record = dict(event)
                record["pr_number"] = pull["number"]
                record["pr_title"] = pull["title"]
                record["pr_url"] = pull["url"]
                handle.write(json.dumps(record, sort_keys=True) + "\n")

    lines = [
        "# Recent maintainer feedback on prior PRs",
        "",
        f"Window: {since.isoformat()} .. {until.isoformat()}",
        f"{total_events} maintainer comment(s)/review(s) across {len(feedback)} PR(s).",
        "",
        "These are changes pwn.college maintainers already requested, corrected, or "
        "rejected on earlier PRs. Do not reintroduce a pattern a maintainer rejected.",
        "",
    ]
    for pull in feedback:
        state = "merged" if pull["merged"] else pull["state"]
        lines.append(f"## PR #{pull['number']} — {pull['title']} ({state})")
        if pull["url"]:
            lines.append(pull["url"])
        lines.append("")
        for event in pull["events"]:
            location = ""
            if event.get("path"):
                location = f" {event['path']}"
                if event.get("line"):
                    location += f":{event['line']}"
            review_state = f" [{event['state']}]" if event.get("state") else ""
            lines.append(
                f"- **{event['kind']}**{review_state} by {event.get('author')}{location}:"
            )
            body = (event.get("body") or "").strip() or "(no body)"
            for body_line in body.splitlines():
                lines.append(f"  > {body_line}")
            lines.append("")
        lines.append("")

    md_path = artifact_dir / "recent-pr-feedback.md"
    md_path.write_text("\n".join(lines).rstrip() + "\n")
    return md_path


def check_run_failures(
    api: GitHubAPI, owner: str, repo_name: str, sha: str
) -> list[dict[str, Any]]:
    failures: list[dict[str, Any]] = []
    page = 1
    while True:
        payload = api.request(
            f"/repos/{owner}/{repo_name}/commits/{sha}/check-runs",
            params={"per_page": 100, "page": page},
        )
        runs = payload.get("check_runs", []) if isinstance(payload, dict) else []
        for run in runs:
            conclusion = run.get("conclusion")
            if (
                run.get("status") == "completed"
                and conclusion in CI_FAILURE_CONCLUSIONS
            ):
                output = run.get("output") or {}
                failures.append(
                    {
                        "kind": "check_run",
                        "id": run.get("id"),
                        "name": run.get("name"),
                        "status": run.get("status"),
                        "conclusion": conclusion,
                        "html_url": run.get("html_url"),
                        "details_url": run.get("details_url"),
                        "started_at": run.get("started_at"),
                        "completed_at": run.get("completed_at"),
                        "output_title": output.get("title"),
                        "output_summary": compact_text(output.get("summary")),
                    }
                )
        if len(runs) < 100:
            return failures
        page += 1


def status_failures(
    api: GitHubAPI, owner: str, repo_name: str, sha: str
) -> list[dict[str, Any]]:
    payload = api.request(f"/repos/{owner}/{repo_name}/commits/{sha}/status")
    statuses = payload.get("statuses", []) if isinstance(payload, dict) else []
    failures = []
    for status in statuses:
        state = status.get("state")
        if state in CI_FAILURE_STATES:
            failures.append(
                {
                    "kind": "status",
                    "id": status.get("id"),
                    "context": status.get("context"),
                    "state": state,
                    "description": status.get("description"),
                    "target_url": status.get("target_url"),
                    "created_at": status.get("created_at"),
                    "updated_at": status.get("updated_at"),
                }
            )
    return failures


def collect_ci_failures(
    api: GitHubAPI, owner: str, repo_name: str, sha: str
) -> list[dict[str, Any]]:
    return [
        *check_run_failures(api, owner, repo_name, sha),
        *status_failures(api, owner, repo_name, sha),
    ]


def ci_failure_fingerprint(sha: str, failures: list[dict[str, Any]]) -> str:
    parts = []
    for failure in failures:
        name = failure.get("name") or failure.get("context") or failure.get("id")
        result = failure.get("conclusion") or failure.get("state")
        parts.append(f"{failure.get('kind')}:{name}:{result}")
    digest = hashlib.sha256("\n".join(sorted(parts)).encode()).hexdigest()[:12]
    return f"{sha}:{digest}"


def extract_actions_run_id(failure: dict[str, Any]) -> Optional[str]:
    for key in ("details_url", "html_url", "target_url"):
        value = failure.get(key) or ""
        match = re.search(r"/actions/runs/(\d+)", value)
        if match:
            return match.group(1)
    return None


def write_ci_failure_artifacts(
    repo: pathlib.Path,
    artifact_dir: pathlib.Path,
    failures: list[dict[str, Any]],
    batch: int,
) -> tuple[pathlib.Path, pathlib.Path]:
    log_dir = artifact_dir / f"ci-failure-logs-{batch:03d}"
    log_dir.mkdir(parents=True, exist_ok=True)
    failures_with_logs = json.loads(json.dumps(failures))
    for index, failure in enumerate(failures_with_logs, start=1):
        run_id = extract_actions_run_id(failure)
        if not run_id:
            continue
        title = safe_title(str(failure.get("name") or run_id))
        log_path = log_dir / f"{index:02d}-{title}.log"
        if not shutil.which("gh"):
            log_path.write_text(
                "gh is not available; failed-job logs were not fetched.\n"
            )
            failure["failed_log"] = str(log_path)
            continue
        try:
            run = subprocess.run(
                ["gh", "run", "view", run_id, "--log-failed"],
                cwd=repo,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                timeout=300,
                check=False,
            )
            log_path.write_text(run.stdout)
            failure["failed_log"] = str(log_path)
            failure["failed_log_exit_code"] = run.returncode
        except subprocess.TimeoutExpired:
            log_path.write_text(f"Timed out fetching failed logs for run {run_id}.\n")
            failure["failed_log"] = str(log_path)
            failure["failed_log_exit_code"] = "timeout"

    failures_path = artifact_dir / f"ci-failures-{batch:03d}.json"
    failures_path.write_text(
        json.dumps(failures_with_logs, indent=2, sort_keys=True) + "\n"
    )
    return failures_path, log_dir


def commit_and_push(repo: pathlib.Path, message: str) -> bool:
    status = git_output(["status", "--porcelain"], repo)
    if not status:
        return False
    subprocess.run(["git", "add", "-A"], cwd=repo, check=True)
    subprocess.run(["git", "commit", "-m", message], cwd=repo, check=True)
    subprocess.run(["git", "push", "-u", "origin", "HEAD"], cwd=repo, check=True)
    return True


def current_short_sha(repo: pathlib.Path) -> str:
    return git_output(["rev-parse", "--short", "HEAD"], repo)


def pr_feedback_reply_body(
    event: dict[str, Any],
    response_text: str,
    commit_sha: Optional[str],
    pushed: bool,
) -> str:
    if pushed and commit_sha:
        status = f"Addressed this feedback and pushed commit `{commit_sha}`."
    else:
        status = (
            "Checked this feedback. No repository changes were necessary for this item."
        )

    lines = [status]
    if event.get("url"):
        lines.extend(["", f"Original feedback: {event['url']}"])

    response_text = with_automation_notice(response_text)
    if response_text.startswith(AUTOMATED_MESSAGE_NOTICE):
        response_text = response_text[len(AUTOMATED_MESSAGE_NOTICE) :].lstrip()
    response_text = compact_text(response_text.strip(), limit=4000)
    if response_text:
        lines.extend(["", "Automated run notes:", "", response_text])
    return "\n".join(lines).rstrip()


def post_pr_event_reply(
    api: GitHubAPI,
    owner: str,
    repo_name: str,
    pr_number: int,
    event: dict[str, Any],
    body: str,
) -> None:
    if event.get("kind") == "review_comment" and event.get("id"):
        post_review_comment_reply(
            api, owner, repo_name, pr_number, int(event["id"]), body
        )
        return

    context = f"In response to {event.get('url') or 'eligible PR feedback'}:"
    post_issue_comment(api, owner, repo_name, pr_number, f"{context}\n\n{body}")


def post_pending_pr_feedback_replies(
    api: GitHubAPI,
    owner: str,
    repo_name: str,
    pr_number: int,
    accepted_events: list[dict[str, Any]],
    state: dict[str, Any],
    state_path: pathlib.Path,
) -> None:
    handled = set(state.get("handled_events", []))
    replied = set(state.get("replied_events", []))
    responses = dict(state.get("event_responses", {}))
    events_by_key = {event.get("key"): event for event in accepted_events}

    for key in sorted(handled - replied):
        event = events_by_key.get(key)
        if not event:
            continue
        response = responses.get(key, {})
        response_path = response.get("path")
        response_text = (
            read_text_if_exists(pathlib.Path(response_path))
            if response_path
            else "The automated watcher handled this feedback in an earlier run."
        )
        body = pr_feedback_reply_body(
            event,
            response_text,
            response.get("commit"),
            bool(response.get("pushed")),
        )
        try:
            post_pr_event_reply(api, owner, repo_name, pr_number, event, body)
        except GitHubAPIError as error:
            # Posting a reply must never crash the watcher. Distinguish permanent failures
            # -- a deleted comment (404) or a validation rejection (422) that retrying
            # can't fix -- from transient ones (5xx, secondary-rate-limit 403, network).
            # Only permanent failures are recorded as handled; transient ones are left
            # unreplied so the next loop retries instead of silently dropping the reply.
            permanent = error.status in (404, 422)
            disposition = "recording it as handled" if permanent else "will retry next loop"
            click.echo(
                f"Could not post automated GitHub reply for {key}: {error}; {disposition}"
            )
            logger.warning("failed to post PR reply for %s: %s", key, error)
            if not permanent:
                continue
        replied.add(key)
        state["replied_events"] = sorted(replied)
        save_watch_state(state_path, state)
        click.echo(f"Recorded automated GitHub reply state for {key}")


def next_watch_batch(state: dict[str, Any]) -> int:
    batch = int(state.get("batch", 0)) + 1
    state["batch"] = batch
    return batch


def watch_pull_request(
    repo: pathlib.Path,
    artifact_dir: pathlib.Path,
    pr_url: str,
    agent: str,
    directions: list[str],
    watch_interval: int,
    max_watch_fix_attempts: int,
) -> None:
    owner, repo_name = github_repo_slug(repo)
    pr_number = parse_pr_number(pr_url)
    api = GitHubAPI.from_environment(repo)
    membership_cache: dict[str, bool] = {}
    state_path = artifact_dir / "pr-watch-state.json"
    state = load_watch_state(state_path)

    click.echo(
        f"Watching PR #{pr_number} for pwncollege/Codex feedback and failing CI "
        f"until it is merged"
    )
    def run_watch_iteration() -> bool:
        """One polling pass. Returns True when the watcher should stop (PR merged/closed).

        Closes over the watch_pull_request locals; mutates state/membership_cache in place.
        """
        pr = get_pull_request(api, owner, repo_name, pr_number)
        if pr.get("merged_at"):
            click.echo(f"PR #{pr_number} is merged; stopping watcher")
            state["merged_at"] = pr.get("merged_at")
            save_watch_state(state_path, state)
            return True
        if pr.get("state") != "open":
            click.echo(f"PR #{pr_number} is {pr.get('state')}; stopping watcher")
            save_watch_state(state_path, state)
            return True

        accepted_events, ignored_events = collect_pr_feedback_events(
            api, owner, repo_name, pr_number, membership_cache
        )
        handled = set(state.get("handled_events", []))
        ignored = set(state.get("ignored_events", []))
        new_ignored = [
            event for event in ignored_events if event.get("key") not in ignored
        ]
        if new_ignored:
            ignored.update(event["key"] for event in new_ignored if event.get("key"))
            state["ignored_events"] = sorted(ignored)
            click.echo(
                f"Ignored {len(new_ignored)} external PR comment/review event(s)"
            )

        post_pending_pr_feedback_replies(
            api, owner, repo_name, pr_number, accepted_events, state, state_path
        )
        handled = set(state.get("handled_events", []))

        new_events = [
            event for event in accepted_events if event.get("key") not in handled
        ]
        if new_events:
            batch = next_watch_batch(state)
            events_path = artifact_dir / f"pr-feedback-events-{batch:03d}.json"
            response_path = artifact_dir / f"pr-feedback-response-{batch:03d}.md"
            events_path.write_text(
                json.dumps(new_events, indent=2, sort_keys=True) + "\n"
            )
            save_watch_state(state_path, state)
            click.echo(
                f"Addressing {len(new_events)} eligible PR comment/review event(s)"
            )
            run_agent(
                agent,
                build_pr_feedback_prompt(pr_url, events_path, response_path, directions),
                repo=repo,
                artifact_dir=artifact_dir,
                output_name=f"pr-feedback-agent-{batch:03d}.log",
                apply=True,
            )
            pushed = commit_and_push(repo, "Address PR feedback")
            if not response_path.exists():
                response_path.write_text(
                    "The PR feedback agent completed without writing a separate "
                    "response artifact.\n"
                )
            response = {
                "commit": current_short_sha(repo),
                "path": str(response_path),
                "pushed": pushed,
            }
            responses = dict(state.get("event_responses", {}))
            for event in new_events:
                if event.get("key"):
                    responses[event["key"]] = response
            state["event_responses"] = responses
            handled.update(event["key"] for event in new_events if event.get("key"))
            state["handled_events"] = sorted(handled)
            save_watch_state(state_path, state)
            if pushed:
                click.echo("Pushed PR feedback fixes")
            else:
                click.echo("PR feedback agent produced no repository changes")
            post_pending_pr_feedback_replies(
                api, owner, repo_name, pr_number, accepted_events, state, state_path
            )
            save_watch_state(state_path, state)
            if pushed:
                time.sleep(min(10, watch_interval))
            return False

        head = pr.get("head") or {}
        sha = head.get("sha")
        if sha:
            failures = collect_ci_failures(api, owner, repo_name, sha)
        else:
            failures = []
        if failures:
            fingerprint = ci_failure_fingerprint(sha, failures)
            attempts = dict(state.get("ci_attempts", {}))
            attempt = int(attempts.get(fingerprint, 0))
            if attempt >= max_watch_fix_attempts:
                click.echo(
                    "CI is still failing for the same head/failure set after "
                    f"{attempt} watcher repair attempt(s); waiting for new signal"
                )
            else:
                batch = next_watch_batch(state)
                attempts[fingerprint] = attempt + 1
                state["ci_attempts"] = attempts
                failures_path, log_dir = write_ci_failure_artifacts(
                    repo, artifact_dir, failures, batch
                )
                response_path = artifact_dir / f"ci-fix-response-{batch:03d}.md"
                save_watch_state(state_path, state)
                click.echo(
                    f"Fixing {len(failures)} failing CI check/status item(s) "
                    f"for {sha[:12]}"
                )
                run_agent(
                    agent,
                    build_ci_fix_prompt(
                        pr_url, failures_path, log_dir, response_path, directions
                    ),
                    repo=repo,
                    artifact_dir=artifact_dir,
                    output_name=f"ci-fix-agent-{batch:03d}.log",
                    apply=True,
                )
                pushed = commit_and_push(repo, "Fix PR CI failures")
                if pushed:
                    click.echo("Pushed CI fixes")
                    time.sleep(min(10, watch_interval))
                else:
                    click.echo("CI fix agent produced no repository changes")
                save_watch_state(state_path, state)
                return False

        save_watch_state(state_path, state)
        click.echo(
            f"No eligible PR feedback or failing CI right now; sleeping {watch_interval}s"
        )
        time.sleep(watch_interval)
        return False

    while True:
        try:
            if run_watch_iteration():
                return
        except (GitHubAPIError, OSError) as error:
            # The watcher must outlive any GitHub/network failure. _request already retries
            # transient HTTP/connection errors; if one still escapes (sustained outage,
            # unexpected status), skip this poll and try again next interval rather than
            # crashing the whole bot.
            click.echo(
                f"Transient error during PR #{pr_number} watch; "
                f"retrying in {watch_interval}s: {error}"
            )
            logger.warning("PR #%s watch iteration failed: %s", pr_number, error)
            time.sleep(watch_interval)


def create_pull_request(
    repo: pathlib.Path,
    artifact_dir: pathlib.Path,
    base_ref: str,
    title: str,
    body_path: pathlib.Path,
    draft: bool,
    require_changes: bool = True,
) -> str:
    if not shutil.which("gh"):
        raise click.ClickException(
            "`gh` is required for --create-pr but is not on PATH."
        )

    if not commit_and_push(repo, title):
        if require_changes:
            raise click.ClickException(
                "No repository changes to commit; refusing to open an empty PR."
            )
        # Resume after an interruption between push and PR creation: the branch is already
        # committed, so there's nothing new to commit -- just make sure it's pushed, then
        # open the PR from the existing commits instead of failing on the clean worktree.
        subprocess.run(["git", "push", "-u", "origin", "HEAD"], cwd=repo, check=True)

    base_branch = base_ref.split("/", 1)[1] if "/" in base_ref else base_ref
    command = [
        "gh",
        "pr",
        "create",
        "--base",
        base_branch,
        "--title",
        title,
        "--body-file",
        str(body_path),
    ]
    if draft:
        command.append("--draft")
    run = subprocess.run(
        command,
        cwd=repo,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=True,
    )
    pr_url = run.stdout.strip()
    (artifact_dir / "pr-url.txt").write_text(pr_url + "\n")
    return pr_url


def load_resume_state(path: pathlib.Path) -> dict[str, Any]:
    if path.exists():
        try:
            state = json.loads(path.read_text())
            if isinstance(state, dict):
                state.setdefault("completed_phases", [])
                return state
        except json.JSONDecodeError:
            pass
    return {"completed_phases": []}


def save_resume_state(path: pathlib.Path, state: dict[str, Any]) -> None:
    path.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n")


# Phases in execution order, with the artifact that proves each one finished. Validation has
# no standalone "passed" marker, but it runs before casts/pr-body/create-pr, so a later
# artifact implies it completed. Used to resume runs created before resume-state.json existed.
_RESUME_PHASE_MARKERS = [
    ("analysis", "analysis.md"),
    ("implementation", "implementation-notes.md"),
    ("validation", None),
    ("casts", "ux-review.md"),
    ("pr-body", "pr-body.md"),
    ("create-pr", "pr-url.txt"),
]


def infer_completed_phases(artifact_dir: pathlib.Path) -> list[str]:
    """Best-effort reconstruction of finished phases from artifacts, for runs with no
    resume-state.json. Phases are sequential, so the furthest non-empty artifact implies all
    earlier phases (validation included) also completed."""

    def present(name: Optional[str]) -> bool:
        if not name:
            return False
        path = artifact_dir / name
        return path.is_file() and path.stat().st_size > 0

    highest = -1
    for index, (_phase, marker) in enumerate(_RESUME_PHASE_MARKERS):
        if present(marker):
            highest = index
    if highest < 0:
        return []
    return [phase for phase, _ in _RESUME_PHASE_MARKERS[: highest + 1]]


def resumed_test_log(
    artifact_dir: pathlib.Path, resume_state: dict[str, Any]
) -> pathlib.Path:
    """The test log to reference for the PR body when validation is reused on resume."""
    stored = resume_state.get("test_log")
    if stored and pathlib.Path(stored).exists():
        return pathlib.Path(stored)
    logs = sorted(artifact_dir.glob("pwnshop-test-attempt-*.log"))
    return logs[-1] if logs else (artifact_dir / "pwnshop-test-skipped.log")


def existing_pr_url(repo: pathlib.Path) -> Optional[str]:
    """URL of an open PR for the current branch, or None (used to resume into watching)."""
    if not shutil.which("gh"):
        return None
    result = subprocess.run(
        ["gh", "pr", "view", "--json", "url", "-q", ".url"],
        cwd=repo,
        capture_output=True,
        text=True,
    )
    return result.stdout.strip() or None


def latest_run_id(artifact_root_dir: pathlib.Path) -> Optional[str]:
    if not artifact_root_dir.is_dir():
        return None
    runs = sorted(p.name for p in artifact_root_dir.iterdir() if p.is_dir())
    return runs[-1] if runs else None


